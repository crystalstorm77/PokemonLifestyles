<!-- SECTION A START — Window + Layout -->
<Window x:Class="LifestylesDesktop.FoodMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Food Menu"
        Height="600"
        Width="700"
        MinHeight="500"
        MinWidth="650">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- SECTION A END — Window + Layout -->

        <!-- SECTION B START — Header -->
        <TextBlock Text="View / Edit Food Menu"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>
        <!-- SECTION B END — Header -->

        <!-- SECTION C START — Data Grid -->
        <DataGrid x:Name="FoodGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridTextColumn Header="kJ/serving" Binding="{Binding KjPerServing, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Serving label" Binding="{Binding ServingLabel, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridTextColumn Header="kJ/100g" Binding="{Binding KjPer100g, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <!-- SECTION C END — Data Grid -->

        <!-- SECTION D START — Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Save changes" Width="120" Margin="0,0,10,0" Click="SaveChanges_Click"/>
            <Button Content="Delete selected" Width="120" Margin="0,0,10,0" Click="DeleteSelected_Click"/>
            <Button Content="Close" Width="80" Click="Close_Click"/>
        </StackPanel>
        <!-- SECTION D END — Buttons -->

        <!-- SECTION E START — Window Close -->
    </Grid>
</Window>
<!-- SECTION E END — Window Close -->