<!-- ============================================================
     SECTION A — Window + Layout
     ============================================================ -->
<Window x:Class="LifestylesDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lifestyles Tracker"
        Height="850"
        Width="1100"
        MinHeight="700"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="16">


            <!-- ============================================================
SECTION B — Input Panel
============================================================ -->

            <TextBlock Text="Lifestyles Tracker" FontWeight="Bold" FontSize="18" Margin="0,0,0,6"/>

            <TextBlock x:Name="TimeZoneText" FontSize="12" Foreground="Gray" Margin="0,0,0,12"/>

            <!-- Archive View Date selector -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">

                <TextBlock Text="Archive View Date:"
                           Width="120"
                           VerticalAlignment="Center"
                           ToolTip="Browsing only. This changes which day you are viewing in the archive. Tracking actions use the current effective game time instead."/>

                <Button x:Name="LogTodayButton"
            Content="View Today"
            Width="90"
            ToolTip="Set Archive View Date to the current game day. If simulated time is enabled, this uses the simulated game day."
            Click="LogTodayButton_Click"/>

                <Button x:Name="LogYesterdayButton"
            Content="View Yesterday"
            Width="110"
            Margin="6,0,0,0"
            ToolTip="Set Archive View Date to the previous game day. If simulated time is enabled, this uses the simulated game day."
            Click="LogYesterdayButton_Click"/>

                <DatePicker x:Name="LogDatePicker"
                Width="140"
                Margin="12,0,0,0"
                ToolTip="Choose a day to browse in the archive."
                SelectedDateChanged="LogDatePicker_SelectedDateChanged"/>
                <TextBlock x:Name="LogDateDisplay"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           ToolTip="The Archive View Date currently being displayed."/>

            </StackPanel>

            <GroupBox Header="Gamification (Debug)" Margin="0,0,0,12">
                <StackPanel Margin="10">

                    <TextBlock Text="Time Travel"
                               FontWeight="Bold"
                               ToolTip="Debug-only clock override. This lets you make the game think it is a different local date and time for testing weekly bonuses and other time-based features."/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="UseSimulatedTimeCheckBox"
                                  Content="Use Simulated Time"
                                  VerticalAlignment="Center"
                                  ToolTip="When checked, the game uses the simulated date and time below instead of the real-world local time."
                                  Checked="UseSimulatedTimeCheckBox_Checked"
                                  Unchecked="UseSimulatedTimeCheckBox_Unchecked"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Simulated Date:"
                                   Width="120"
                                   VerticalAlignment="Center"
                                   ToolTip="Choose the local date that the game should treat as 'now' when simulated time is enabled."/>
                        <DatePicker x:Name="SimulatedDatePicker"
                                    Width="150"
                                    Margin="0,0,12,0"
                                    ToolTip="Choose the simulated local date."
                                    SelectedDateChanged="SimulatedDatePicker_SelectedDateChanged"/>

                        <TextBlock Text="Simulated Time:"
                                   Width="120"
                                   VerticalAlignment="Center"
                                   ToolTip="Enter the simulated local time in HH:mm:ss format. The simulated clock continues ticking forward after you apply it."/>
                        <TextBox x:Name="SimulatedTimeBox"
                                 Width="100"
                                 ToolTip="Format: HH:mm:ss"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="TimeTravelBackOneDayButton"
                                Content="Back 1 Day"
                                Width="100"
                                ToolTip="Move the simulated date picker back by one day. If simulated time is already active, the new date is applied immediately."
                                Click="TimeTravelBackOneDayButton_Click"/>

                        <Button x:Name="TimeTravelForwardOneDayButton"
                                Content="Forward 1 Day"
                                Width="110"
                                Margin="8,0,0,0"
                                ToolTip="Move the simulated date picker forward by one day. If simulated time is already active, the new date is applied immediately."
                                Click="TimeTravelForwardOneDayButton_Click"/>

                        <Button x:Name="ApplySimulatedTimeButton"
                                Content="Apply"
                                Width="80"
                                Margin="8,0,0,0"
                                ToolTip="Apply the selected simulated date and time and turn simulated time on."
                                Click="ApplySimulatedTimeButton_Click"/>

                        <Button x:Name="ResetTimeToNowLocalButton"
                                Content="Reset Time to 'Now (Local)'"
                                Width="180"
                                Margin="8,0,0,0"
                                ToolTip="Turn simulated time off and sync the simulated date and time controls back to the real local clock."
                                Click="ResetTimeToNowLocalButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="NowLocalText"
                               Foreground="Gray"
                               Margin="0,8,0,0"
                               ToolTip="The real-world local date and time outside the game. This does not change when simulated time is enabled."/>

                    <TextBlock x:Name="SimulatedDateTimeText"
                               Foreground="Gray"
                               Margin="0,2,0,0"
                               ToolTip="The date and time the game is currently using as 'now'. This matches Now (Local) when simulated time is off."/>

                    <TextBlock x:Name="GameDayNowText"
                               Foreground="Gray"
                               Margin="0,2,0,0"
                               ToolTip="The game's current day after applying the 03:00 rollover rule. For example, 02:30 still counts as the previous day."/>

                    <TextBlock x:Name="RewardsSummaryText" Margin="0,6,0,0"/>

                    <TextBlock x:Name="SleepMultiplierText" Foreground="Gray" Margin="0,2,0,0"/>

                    <Separator Margin="0,10,0,10"/>

                    <TextBlock x:Name="StepItemDropsHeaderText"
                               Text="Step item drops (from steps)"
                               FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                        <TextBlock Text="Steps/roll:" Width="80" VerticalAlignment="Center"/>

                        <TextBox x:Name="StepsPerRollBox" Width="80" Margin="0,0,12,0"/>

                        <TextBlock Text="Odds (1 in):" Width="80" VerticalAlignment="Center"/>

                        <TextBox x:Name="OddsOneInBox" Width="60" Margin="0,0,12,0"/>

                    </StackPanel>

                    <TextBlock x:Name="ItemDropsProgressText" Foreground="Gray" Margin="0,6,0,0"/>

                    <TextBlock x:Name="ItemDropsStatsText" Foreground="Gray" Margin="0,2,0,0"/>
                    <TextBlock x:Name="ItemDropsLastText"
                               Foreground="Gray"
                               Margin="0,2,0,0"
                               MaxWidth="520"
                               TextWrapping="Wrap"/>

                    <!-- Tier weights -->

                    <TextBlock Text="Tier weights (used only when a roll succeeds):" Margin="0,10,0,2"/>

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Common:" Width="70" VerticalAlignment="Center"/>

                        <TextBox x:Name="CommonWeightBox" Width="60" Margin="0,0,12,0"/>

                        <TextBlock Text="Uncommon:" Width="80" VerticalAlignment="Center"/>

                        <TextBox x:Name="UncommonWeightBox" Width="60" Margin="0,0,12,0"/>
                        <TextBlock Text="Rare:" Width="45" VerticalAlignment="Center"/>

                        <TextBox x:Name="RareWeightBox" Width="60" Margin="0,0,12,0"/>

                    </StackPanel>

                    <!-- Save + Reset are directly under the tier weights -->

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">

                        <Button Content="Save drop settings" Width="130" Click="SaveItemDropSettings_Click"/>

                        <Button Content="Reset tier weights" Width="130" Margin="6,0,0,0" Click="ResetTierWeights_Click"/>

                    </StackPanel>

                    <!-- Item list editor -->

                    <TextBlock Text="Drop items list:" FontWeight="Bold" Margin="0,10,0,4"/>

                    <!-- Clearer labeled inputs -->

                    <StackPanel Margin="0,0,0,6">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">

                            <TextBlock Text="Item:" Width="65" VerticalAlignment="Center"/>

                            <TextBox x:Name="NewItemNameBox" Width="150" Margin="0,0,10,0" ToolTip="New item name"/>

                            <TextBlock Text="Category:" Width="75" VerticalAlignment="Center"/>
                            <TextBox x:Name="NewItemCategoryBox" Width="170" ToolTip="Optional category (e.g. Healing, Ball, Status)"/>

                        </StackPanel>

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="Tier:" Width="65" VerticalAlignment="Center"/>

                            <ComboBox x:Name="NewItemTierCombo"
                          Width="150"
                          Margin="0,0,10,0"
                          ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemTierChoices}"
                          SelectedIndex="0"/>

                            <TextBlock Text="Weight:" Width="60" VerticalAlignment="Center"/>

                            <TextBox x:Name="NewItemWeightBox" Width="70" Margin="0,0,10,0" Text="1" ToolTip="Weight within the selected tier"/>

                            <Button Content="Add" Width="80" Click="AddItemDefinition_Click"/>

                        </StackPanel>

                    </StackPanel>

                    <DataGrid x:Name="ItemDefinitionsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Height="160"
                  Margin="0,0,0,2"
                  ColumnWidth="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" IsReadOnly="True"/>

                            <DataGridTextColumn Header="Category" Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>

                            <DataGridTemplateColumn Header="Tier" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Tier}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Width="120"
                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemTierChoices}"
                                      SelectedItem="{Binding Tier, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Weight" Binding="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>

                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>

                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Save grid edits" Width="110" Click="SaveItemDefinitions_Click"/>
                        <Button Content="Deactivate selected" Width="140" Margin="6,0,0,0" Click="DeleteSelectedItemDefinition_Click"/>
                        <Button Content="Reset item list..." Width="120" Margin="6,0,0,0" Click="ResetItemList_Click"/>
                    </StackPanel>

                    <TextBlock Text="Tip: Add saves immediately. “Save grid edits” is only for changes you make inside the grid (Category/Tier/Weight/Active)."
                   Foreground="Gray"
                   FontStyle="Italic"
                   FontSize="11"
                   Margin="0,2,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                        <TextBlock x:Name="InventoryCountText" VerticalAlignment="Center"/>

                        <Button Content="Clear inventory"
                    Width="110"
                    Margin="10,0,0,0"
                    Click="ClearInventory_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="InventoryGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  Height="140">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemKey}" Width="*"/>

                            <DataGridTemplateColumn Header="Count" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="-" Width="28" Padding="0"
                                        Tag="{Binding ItemKey}"
                                        Click="InventoryMinus_Click"/>
                                            <TextBlock Text="{Binding Count}" Width="60" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <Button Content="+" Width="28" Padding="0"
                                        Tag="{Binding ItemKey}"
                                        Click="InventoryPlus_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </GroupBox>
            <!-- ============================================================
SECTION C — Focus Session Input
============================================================ -->

            <!-- Focus Session -->
            <GroupBox Header="Focus Session" Margin="0,0,0,12">
                <StackPanel Margin="10">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Focus Type:" Width="90" VerticalAlignment="Center"/>

                        <ComboBox x:Name="FocusTypeCombo"
                Width="200"
                IsEditable="True"
                IsTextSearchEnabled="True"
                StaysOpenOnEdit="True"
                ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FocusLabelChoices}"/>

                        <Button x:Name="ManageFocusLabelsButton"
              Content="Manage..."
              Width="90"
              Margin="10,0,0,0"
              Click="ManageFocusLabels_Click"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,10"/>

                    <TextBlock Text="Live Timer" FontWeight="Bold" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Mode:" Width="90" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FocusTimerModeCombo"
                  Width="140"
                  SelectedIndex="0"
                  SelectionChanged="FocusTimerModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Countdown"/>
                            <ComboBoxItem Content="Count Up"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="FocusCountUpDebugStartRow" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                        <TextBlock Text="Debug Start From:" Width="120" VerticalAlignment="Center"/>
                        <TextBox x:Name="FocusCountUpDebugStartMinutesBox"
                 Width="120"
                 Text="0"
                 Margin="0,0,10,0"
                 TextChanged="FocusTimerDebugTextChanged"/>
                        <TextBlock Text="elapsed whole minutes" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="FocusCountdownMinutesRow" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Countdown:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="FocusCountdownMinutesBox"
                 Width="120"
                 Text="25"
                 Margin="0,0,10,0"
                 TextChanged="FocusCountdownMinutesBox_TextChanged"/>
                        <TextBlock Text="5 to 120 minutes" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="FocusCountdownDebugRemainingRow" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Debug Remaining:" Width="120" VerticalAlignment="Center"/>
                        <TextBox x:Name="FocusCountdownDebugRemainingMinutesBox"
                 Width="120"
                 Text="0"
                 Margin="0,0,10,0"
                 TextChanged="FocusTimerDebugTextChanged"/>
                        <TextBlock Text="remaining whole minutes" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Width="250"
            HorizontalAlignment="Left"
            BorderBrush="#FFBFBFBF"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            Margin="0,0,0,8">
                        <TextBlock x:Name="FocusTimerDisplayText"
                   Text="00:25:00"
                   FontSize="24"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="FocusTimerStatusText"
               Text="Countdown timer ready. Choose 5 to 120 minutes and press Start Focus."
               Foreground="Gray"
               TextWrapping="Wrap"
               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="StartFocusTimerButton"
                Content="Start Focus"
                Width="110"
                Click="StartFocusTimerButton_Click"/>
                        <Button x:Name="PauseFocusTimerButton"
                Content="Pause"
                Width="100"
                Margin="10,0,0,0"
                Click="PauseFocusTimerButton_Click"
                Visibility="Collapsed"
                IsEnabled="False"/>
                        <Button x:Name="StopFocusTimerButton"
                Content="Stop Focusing"
                Width="120"
                Margin="10,0,0,0"
                Click="StopFocusTimerButton_Click"
                IsEnabled="False"/>
                    </StackPanel>

                    <Separator Margin="0,10,0,10"/>

                    <TextBlock Text="Manual Entry" FontWeight="Bold" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Minutes:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="MinutesBox" Width="120" Margin="0,0,10,0"/>
                        <CheckBox x:Name="CompletedCheck" Content="Completed" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="AddFocusButton"
            Content="Add Focus Session"
            Width="200"
            Click="AddFocusButton_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- Food -->
            <GroupBox Header="Food" Margin="0,0,0,12">
                <StackPanel Margin="10">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Food:" Width="90" VerticalAlignment="Center"/>

                        <ComboBox x:Name="FoodCombo"
                Width="240"
                DisplayMemberPath="Name"
                IsTextSearchEnabled="True"
                Margin="0,0,10,0"/>

                        <Button x:Name="ViewFoodMenuButton"
              Content="View / Edit Menu..."
              Width="140"
              Click="ViewFoodMenuButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Servings:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="FoodServingsBox" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="Optional" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Grams:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="FoodGramsBox" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="Optional" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="AddFoodEntryButton"
            Content="Add Food Entry"
            Width="200"
            Click="AddFoodEntryButton_Click"/>

                    <Separator Margin="0,10,0,10"/>

                    <TextBlock Text="Food Menu (Add new item)" FontWeight="Bold" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Name:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewFoodNameBox" Width="240"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Serving label:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewFoodServingLabelBox" Width="240" Margin="0,0,10,0"/>
                        <TextBlock Text="Optional" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="kJ/serving:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewFoodKjPerServingBox" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="Required" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="kJ/100g:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="NewFoodKjPer100gBox" Width="120" Margin="0,0,10,0"/>
                        <TextBlock Text="Optional" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="AddFoodToMenuButton"
            Content="Add to Food Menu"
            Width="200"
            Click="AddFoodToMenuButton_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- Sleep -->
            <GroupBox Header="Sleep" Margin="0,0,0,12">
                <StackPanel Margin="10">

                    <TextBlock x:Name="PendingSleepText" Foreground="Gray" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="StartSleepNowButton"
              Content="Start Sleep (now)"
              Width="200"
              Margin="0,0,10,0"
              Click="StartSleepNow_Click"/>

                        <Button x:Name="EndSleepNowButton"
              Content="End Sleep (now)"
              Width="200"
              Click="EndSleepNow_Click"/>
                    </StackPanel>

                    <TextBlock Text="Sleep is credited to the wake-up day."
               FontStyle="Italic"
               Foreground="Gray"
               Margin="0,8,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Steps (testing-only on desktop) -->
            <GroupBox Header="Steps (Testing)" Margin="0,0,0,12">
                <StackPanel Margin="10">

                    <TextBlock x:Name="StepsDayText" FontWeight="Bold" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Add steps:" Width="90" VerticalAlignment="Center"/>
                        <TextBox x:Name="StepsAddBox" Width="120" Margin="0,0,10,0"/>

                        <Button x:Name="AddStepsButton"
              Content="Add Steps"
              Width="110"
              Click="AddStepsButton_Click"/>

                        <Button x:Name="ViewStepsBucketsButton"
              Content="View buckets..."
              Width="120"
              Margin="10,0,0,0"
              Click="ViewStepsBucketsButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <TextBlock Text="At (optional):" Width="90" VerticalAlignment="Center"
                                   ToolTip="Leave blank to use the current effective date and time. If simulated time is enabled, blank uses the simulated date and time."/>
                        <TextBox x:Name="StepsAtBox" Width="240"
               ToolTip="Local time: yyyy-MM-dd HH:mm or yyyy-MM-dd HH:mm:ss. Leave blank to use the current effective date and time."/>
                    </StackPanel>

                    <TextBlock Text="Steps are stored in 15-minute buckets."
               Foreground="Gray"
               FontStyle="Italic"
               Margin="0,8,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Data -->
            <GroupBox Header="Data" Margin="0,0,0,12">
                <StackPanel Margin="10">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BackupEverythingButton"
              Content="Backup Everything..."
              Width="220"
              Margin="0,0,10,0"
              Click="BackupEverythingButton_Click"/>

                        <Button x:Name="RestoreDbButton"
              Content="Restore Full App Snapshot..."
              Width="220"
              Click="RestoreDbButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="ImportArchiveMergeButton"
              Content="Import Database Archive (Merge)..."
              Width="220"
              Margin="0,0,10,0"
              Click="ImportArchiveMergeButton_Click"/>

                        <Button x:Name="ImportArchiveRangeButton"
              Content="Import Database Archive (Replace Date Range)..."
              Width="320"
              Click="ImportArchiveRangeButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="ExportGamificationButton"
              Content="Export Gamification Save..."
              Width="220"
              Margin="0,0,10,0"
              Click="ExportGamificationButton_Click"/>

                        <Button x:Name="ImportGamificationButton"
              Content="Import Gamification Save..."
              Width="220"
              Click="ImportGamificationButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="DeleteAllDataButton"
              Content="Delete All Data..."
              Width="150"
              Margin="0,0,10,0"
              Click="DeleteAllDataButton_Click"/>

                        <Button x:Name="DeleteAllDatabaseDataButton"
              Content="Delete All Database Data..."
              Width="180"
              Margin="0,0,10,0"
              Click="DeleteAllDatabaseDataButton_Click"/>

                        <Button x:Name="DeleteAllGamificationDataButton"
              Content="Delete All Gamification Data..."
              Width="190"
              Click="DeleteAllGamificationDataButton_Click"/>
                    </StackPanel>

                    <TextBlock Text="Backup Everything creates a dated folder containing a full app snapshot, a Database Archive folder, and a gamification save file."
               Foreground="Gray"
               FontStyle="Italic"
               TextWrapping="Wrap"/>

                    <TextBlock Text="For database archive imports, choose the Database Archive folder itself — the one containing manifest.json and the year folders."
               Foreground="Gray"
               FontStyle="Italic"
               Margin="0,4,0,0"
               TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>
            <!-- ============================================================
                 SECTION D — Sessions Header
                 ============================================================ -->
            <TextBlock x:Name="SessionsHeaderText"
                       Text="Sessions"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <!-- ============================================================
SECTION E — Sessions List
============================================================ -->
            <TabControl x:Name="SessionsTabControl"
SelectionChanged="SessionsTabControl_SelectionChanged"
Margin="0,0,0,0"
Height="520">

                <!-- ============================================================
SECTION F — Focus Sessions Tab
============================================================ -->

                <TabItem Header="Focus Sessions">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="FocusSessionsGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Logged"
                                    Binding="{Binding LoggedAtLocalEdit, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGridTemplateColumn Header="Type">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FocusType}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      StaysOpenOnEdit="True"
                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FocusLabelChoices}"
                                      Text="{Binding FocusType, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Minutes"
                                    Binding="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGridCheckBoxColumn Header="Completed"
                                        Binding="{Binding Completed, UpdateSourceTrigger=PropertyChanged}"/>

                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Save changes" Width="120" Margin="0,0,10,0" Click="SaveFocusSessionsChanges_Click"/>
                            <Button Content="Delete selected" Width="120" Click="DeleteSelectedFocusSession_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Food Entries">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="FoodTotalText" FontWeight="Bold" Margin="0,0,0,8"/>

                        <DataGrid x:Name="FoodEntriesGrid"
          Grid.Row="1"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          SelectionMode="Single"
          SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Logged"
                            Binding="{Binding LoggedAtLocalEdit, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Food"
                            Binding="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Servings"
                            Binding="{Binding Servings, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Grams"
                            Binding="{Binding Grams, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Kilojoules"
                            Binding="{Binding KjComputed, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Save changes" Width="120" Margin="0,0,10,0" Click="SaveFoodEntriesChanges_Click"/>
                            <Button Content="Delete selected" Width="120" Click="DeleteSelectedFoodEntry_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Sleep Sessions">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SleepTotalText" FontWeight="Bold" Margin="0,0,0,8"/>

                        <DataGrid x:Name="SleepSessionsGrid"
          Grid.Row="1"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          SelectionMode="Single"
          SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Start"
                            Binding="{Binding StartLocalEdit, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="End"
                            Binding="{Binding EndLocalEdit, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Hours"
                            Binding="{Binding DurationHours, StringFormat=F2}"
                            IsReadOnly="True"/>
                                <DataGridTextColumn Header="Wake day"
                            Binding="{Binding WakeLogDateEdit}"
                            IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Save changes" Width="120" Margin="0,0,10,0" Click="SaveSleepSessionsChanges_Click"/>
                            <Button Content="Delete selected" Width="120" Click="DeleteSelectedSleepSession_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Habits -->
                <TabItem Header="Habits">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Create habit -->
                        <GroupBox Header="Create Habit" Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Title:" Width="70" VerticalAlignment="Center"/>
                                    <TextBox x:Name="HabitTitleBox" Width="300"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Type:" Width="70" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="HabitKindCombo" Width="160" SelectedIndex="0" Margin="0,0,10,0">
                                        <ComboBoxItem Content="Checkbox (daily)"/>
                                        <ComboBoxItem Content="Counter (daily)"/>
                                    </ComboBox>

                                    <TextBlock Text="Target/wk:" Width="80" VerticalAlignment="Center"/>
                                    <TextBox x:Name="HabitTargetBox" Width="80"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="AddHabitButton"
                    Content="Add Habit"
                    Width="140"
                    Click="AddHabitButton_Click"/>
                                </StackPanel>

                                <TextBlock Text="Checkbox habits count days completed. Counter habits sum totals across the week."
                   Foreground="Gray" FontStyle="Italic" Margin="0,8,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Log counter progress (additive) -->
                        <GroupBox Header="Log Progress (Counter habits)" Grid.Row="1" Margin="0,0,0,10">
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Habit:" Width="70" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="HabitLogCombo" Width="240" DisplayMemberPath="Title" Margin="0,0,10,0"/>
                                    <TextBlock Text="Add:" Width="40" VerticalAlignment="Center"/>
                                    <TextBox x:Name="HabitAddAmountBox" Width="70" Margin="0,0,10,0"/>
                                    <Button x:Name="AddHabitAmountButton" Content="Add" Width="70" Click="AddHabitAmountButton_Click"/>
                                </StackPanel>

                                <TextBlock Text="This adds to the selected day’s total (safer than overwriting). You can still manually edit past days in the table below if needed."
                   Foreground="Gray"
                   FontStyle="Italic"/>
                            </StackPanel>
                        </GroupBox>

                        <TextBlock x:Name="HabitsWeekText"
           Grid.Row="2"
           FontWeight="Bold"
           Margin="0,0,0,8"/>

                        <DataGrid x:Name="HabitsGrid"
          Grid.Row="3"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          SelectionMode="Single"
          SelectionUnit="FullRow">

                            <!-- Right-click should select the row you clicked -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <EventSetter Event="PreviewMouseRightButtonDown"
                         Handler="HabitsGridRow_PreviewMouseRightButtonDown"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <!-- Context menu operates on selection -->
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Archive"
                      Click="ArchiveSelectedHabit_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Habit"
                            IsReadOnly="True"
                            Binding="{Binding Title}"/>

                                <DataGridTextColumn Header="Type"
                            IsReadOnly="True"
                            Binding="{Binding KindLabel}"/>

                                <DataGridTextColumn Header="Target/wk"
                            IsReadOnly="True"
                            Binding="{Binding TargetPerWeek}"/>

                                <!-- Archived today (CLICK only; avoids refresh storms) -->
                                <DataGridTemplateColumn Header="Archived today">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding ArchivedOnSelectedDate, Mode=OneWay}"
                              Click="HabitArchivedToday_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Checkbox-only / Counter display -->
                                <DataGridTemplateColumn Header="Done / Show">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <!-- Checkbox habits: editable Done checkbox -->
                                                <CheckBox IsChecked="{Binding TodayChecked, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCheckbox}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>

                                                <!-- Counter habits: show label so the column isn't blank -->
                                                <TextBlock Text="Show"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCounter}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Counter-only -->
                                <DataGridTemplateColumn Header="Today total">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCounter}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <Button Content="-" Width="22" Margin="0,0,4,0" Click="CounterMinus_Click"/>
                                                <TextBox Text="{Binding TodayValue, UpdateSourceTrigger=PropertyChanged}" Width="60"
                                                         HorizontalContentAlignment="Center"/>
                                                <Button Content="+" Width="22" Margin="4,0,0,0" Click="CounterPlus_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="This week"
                            IsReadOnly="True"
                            Binding="{Binding WeekTotal}"/>

                                <DataGridCheckBoxColumn Header="Met?"
                                IsReadOnly="True"
                                Binding="{Binding WeekMet}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Bottom-right actions -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Save changes"
            Width="120"
            Margin="0,0,10,0"
            Click="SaveHabitsChanges_Click"/>
                            <Button Content="Archive selected"
            Width="120"
            Click="ArchiveSelectedHabit_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>

        </StackPanel>
    </ScrollViewer>
</Window>