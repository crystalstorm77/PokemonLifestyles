<!-- SECTION A START — Window + Layout -->
<Window x:Class="LifestylesDesktop.StepsBucketsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Step Buckets"
        Height="520"
        Width="420"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- SECTION A END — Window + Layout -->

        <!-- SECTION B START — Header -->
        <TextBlock x:Name="HeaderText"
                   Grid.Row="0"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>
        <!-- SECTION B END — Header -->

        <!-- SECTION C START — Buckets Grid -->
        <DataGrid x:Name="BucketsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Local start" Binding="{Binding LocalBucketStart}"/>
                <DataGridTextColumn Header="Steps" Binding="{Binding Steps}"/>
                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedLocal}"/>
            </DataGrid.Columns>
        </DataGrid>
        <!-- SECTION C END — Buckets Grid -->

        <!-- SECTION D START — Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Close"
                    Width="90"
                    Click="Close_Click"/>
        </StackPanel>
        <!-- SECTION D END — Buttons -->

        <!-- SECTION E START — Window Close -->
    </Grid>
</Window>
<!-- SECTION E END — Window Close -->