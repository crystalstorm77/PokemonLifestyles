@page
@model LifestylesWeb.Pages.PagesIndexModel
@{
    ViewData["Title"] = "Home";
}
@* SEGMENT A1 START - Home Canvas Stage Markup *@
<div class="pl-home-stage-shell" id="pl-home-stage-shell">
    <div class="pl-home-stage" id="pl-home-stage">
        <div class="pl-screen pl-home-screen"
             id="pl-home-root"
             data-focus-labels="@Model.FocusLabelsJson"
             data-reward-xp-per-minute="@Model.RewardPreviewFocusXpPerMinute"
             data-reward-incomplete-multiplier="@Model.RewardPreviewIncompleteMultiplier"
             data-reward-sleep-multiplier="@Model.RewardPreviewSleepMultiplier"
             data-reward-window-eligible="@Model.RewardWindowEligible.ToString().ToLowerInvariant()"
             data-show-reward-overlay="@Model.ShowRewardOverlay.ToString().ToLowerInvariant()"
             data-reward-focus-type="@Model.RewardFocusType"
             data-reward-duration="@Model.FormatDuration(Model.RewardDurationSeconds)"
             data-reward-completed="@Model.RewardCompleted.ToString().ToLowerInvariant()"
             data-reward-xp="@Model.RewardXp"
             data-reward-coins="@Model.RewardCoins">

            <div class="pl-world-stage-shell" id="pl-world-stage-shell" aria-hidden="true">
                <div class="pl-world-stage" id="pl-world-stage">
                    <div class="pl-canvas-item pl-home-scene-art" id="pl-home-scene-art" aria-hidden="true"></div>
                </div>
            </div>

            <div class="pl-safe-zone-outline" id="pl-safe-zone-outline" hidden aria-hidden="true"></div>

            <div class="pl-safe-ui-stage-shell" id="pl-safe-ui-stage-shell">
                <div class="pl-safe-ui-stage" id="pl-safe-ui-stage">
                    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                    {
                        <div class="pl-status-toast">@Model.StatusMessage</div>
                    }

                    <div class="pl-layout-component-outline" id="pl-layout-component-outline" hidden aria-hidden="true"></div>
                    <div class="pl-layout-hit-outline" id="pl-layout-hit-outline" hidden aria-hidden="true"></div>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-home-focus"
                            id="pl-home-focus-button">
                        <span class="pl-button-label">Focus</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-home-sleep"
                            id="pl-home-sleep-button"
                            disabled>
                        <span class="pl-button-label">Sleep</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-layout-debug"
                            id="pl-open-layout-mode-button">
                        <span class="pl-button-label">Layout</span>
                    </button>

                    <div class="pl-canvas-item pl-canvas-panel pl-canvas-panel-setup" id="pl-setup-panel" hidden>
                        <div class="pl-setup-copy">
                            <div class="pl-panel-header">
                                <span class="pl-eyebrow" style="margin:0;">Focus Session</span>
                                <span class="pl-badge" id="pl-setup-mode-badge">Count Down</span>
                            </div>

                            <h2 class="pl-title" style="margin-top:0.55rem;">Stay with it</h2>
                            <p class="pl-subtitle" id="pl-setup-mode-hint">
                                Count Down uses the slider. Count Up starts a stopwatch that checkpoints every 2 hours.
                            </p>
                        </div>

                        <div class="pl-setup-controls" id="pl-setup-controls"></div>
                    </div>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-countdown-mode"
                            id="pl-countdown-mode-button"
                            hidden>
                        <span class="pl-button-label">Count Down</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-countup-mode"
                            id="pl-countup-mode-button"
                            hidden>
                        <span class="pl-button-label">Count Up</span>
                    </button>

                    <p class="pl-canvas-item pl-field-label pl-focus-type-label-asset" id="pl-focus-type-label" hidden>
                        Focus type
                    </p>

                    <label class="pl-canvas-item pl-canvas-form-field pl-focus-type-field-asset" id="pl-focus-type-field" hidden>
                        <input class="pl-input" id="pl-focus-type-input" type="text" maxlength="40" value="@Model.InitialFocusType" hidden />
                        <div class="pl-focus-type-picker" id="pl-focus-type-picker" aria-label="Focus type picker">
                            <div class="pl-focus-type-picker-fade pl-focus-type-picker-fade-top" aria-hidden="true"></div>
                            <div class="pl-focus-type-picker-selection" aria-hidden="true"></div>
                            <div class="pl-focus-type-picker-fade pl-focus-type-picker-fade-bottom" aria-hidden="true"></div>
                            <div class="pl-focus-type-picker-viewport"
                                 id="pl-focus-type-picker-viewport"
                                 tabindex="0"
                                 role="listbox"
                                 aria-label="Focus type">
                                <div class="pl-focus-type-picker-list" id="pl-focus-type-picker-list"></div>
                            </div>
                        </div>
                    </label>

                    <div class="pl-canvas-item pl-canvas-duration-text" id="pl-duration-text" hidden>
                        <span class="pl-canvas-duration-text-label" id="pl-duration-text-label">
                            <span class="pl-canvas-duration-part">
                                <span class="pl-canvas-duration-value" id="pl-duration-hours-value">0</span>
                                <span class="pl-canvas-duration-unit" id="pl-duration-hours-unit">hours</span>
                            </span>
                            <span class="pl-canvas-duration-part">
                                <span class="pl-canvas-duration-value" id="pl-duration-minutes-value">5</span>
                                <span class="pl-canvas-duration-unit">min</span>
                            </span>
                            <span class="pl-canvas-duration-part">
                                <span class="pl-canvas-duration-value" id="pl-duration-seconds-value">0</span>
                                <span class="pl-canvas-duration-unit">sec</span>
                            </span>
                        </span>
                    </div>

                    <div class="pl-canvas-item pl-slider-group" id="pl-slider-group" hidden>
                        <div class="pl-slider-track-shell" id="pl-slider-track-shell">
                            <div class="pl-slider-track-empty-art" id="pl-slider-track-empty-art" aria-hidden="true"></div>
                        </div>

                        <div class="pl-slider-fill-shell" id="pl-slider-fill-shell">
                            <div class="pl-slider-fill-art" id="pl-slider-fill-art" aria-hidden="true"></div>
                        </div>

                        <div class="pl-slider-nib-visual" id="pl-slider-nib-visual" aria-hidden="true"></div>

                        <input class="pl-slider-input-overlay"
                               id="pl-duration-slider"
                               type="range"
                               min="5"
                               max="120"
                               step="1"
                               value="5"
                               aria-label="Countdown length" />
                    </div>

                    <div class="pl-canvas-item pl-bar-asset" id="pl-bar" hidden aria-hidden="true"></div>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-start"
                            id="pl-start-focus-button"
                            hidden>
                        <span class="pl-button-label">Start</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-back"
                            id="pl-close-focus-button"
                            hidden>
                        <span class="pl-button-label">Back</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-back"
                            id="pl-manage-button"
                            hidden>
                        <span class="pl-button-label">Manage</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-pause"
                            id="pl-pause-button"
                            hidden>
                        <span class="pl-button-label">Pause</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-exit"
                            id="pl-exit-button"
                            hidden>
                        <span class="pl-button-label">Cancel</span>
                    </button>

                    <div class="pl-canvas-item pl-canvas-panel pl-canvas-panel-focus-manage" id="pl-focus-manage-panel" hidden></div>

                    <div class="pl-canvas-item pl-focus-manage-list-shell-asset" id="pl-focus-manage-list-shell" hidden>
                        <div class="pl-focus-manage-list-shell-lower" id="pl-focus-manage-list-shell-lower" aria-hidden="true"></div>
                        <div class="pl-focus-manage-list-viewport" id="pl-focus-manage-list-viewport">
                            <div class="pl-focus-manage-list" id="pl-focus-manage-list" role="grid" aria-label="Focus type tiles"></div>
                        </div>
                        <div class="pl-focus-manage-list-scrollbar-visual" id="pl-focus-manage-list-scrollbar-visual" hidden aria-hidden="true"></div>
                        <div class="pl-focus-manage-list-shell-upper" id="pl-focus-manage-list-shell-upper" aria-hidden="true"></div>
                    </div>

                    <p class="pl-focus-manage-status" id="pl-focus-manage-status" aria-live="polite" hidden>
                        Select a tile, then tap another tile to swap positions.
                    </p>

                    <p class="pl-canvas-item pl-field-label pl-focus-manage-input-label-asset" id="pl-focus-manage-input-label" hidden>
                        Focus Type
                    </p>

                    <label class="pl-canvas-item pl-canvas-form-field pl-focus-manage-input-asset" id="pl-focus-manage-input-field" hidden>
                        <input class="pl-input"
                               id="pl-focus-manage-input"
                               type="text"
                               maxlength="40"
                               placeholder="Type a focus label" />
                    </label>

                    <button type="button"
                            class="pl-canvas-item pl-focus-manage-action-button"
                            id="pl-focus-manage-add-button"
                            hidden>
                        <span class="pl-button-label">Add</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-focus-manage-action-button pl-focus-manage-action-button-danger"
                            id="pl-focus-manage-delete-button"
                            hidden>
                        <span class="pl-button-label">Remove</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-back"
                            id="pl-focus-manage-back-button"
                            hidden>
                        <span class="pl-button-label">Cancel</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-start"
                            id="pl-focus-manage-ok-button"
                            hidden>
                        <span class="pl-button-label">Save</span>
                    </button>

                    <div class="pl-canvas-item pl-canvas-panel pl-canvas-panel-focus-manage-confirm" id="pl-focus-manage-confirm-panel" hidden></div>

                    <p class="pl-canvas-item pl-eyebrow pl-focus-manage-confirm-title" id="pl-focus-manage-confirm-title" hidden>
                        Save changes?
                    </p>

                    <p class="pl-canvas-item pl-subtitle pl-focus-manage-confirm-message" id="pl-focus-manage-confirm-message" hidden>
                        Removed labels leave archive data untouched. You can add them back at any time.
                    </p>

                    <button type="button"
                            class="pl-canvas-item pl-focus-manage-action-button pl-focus-manage-action-button-danger"
                            id="pl-focus-manage-confirm-delete-button"
                            hidden>
                        <span class="pl-button-label">Save</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-focus-manage-action-button pl-focus-manage-action-button-secondary"
                            id="pl-focus-manage-confirm-cancel-button"
                            hidden>
                        <span class="pl-button-label">Cancel</span>
                    </button>

                    <label class="pl-canvas-item pl-focus-manage-confirm-dismiss-asset" id="pl-focus-manage-confirm-dismiss-field" hidden>
                        <input id="pl-focus-manage-confirm-dismiss-input" type="checkbox" />
                        <span>Don't remind me again</span>
                    </label>

                    <div class="pl-panel-dim pl-canvas-item" id="pl-confirm-dim" hidden></div>

                    <div class="pl-canvas-item pl-canvas-panel pl-canvas-panel-confirm" id="pl-confirm-panel" hidden>
                        <p class="pl-eyebrow" id="pl-confirm-eyebrow" hidden aria-hidden="true">Stop Focusing</p>
                        <h2 class="pl-section-title" id="pl-confirm-title" hidden aria-hidden="true">Are you sure?</h2>
                        <p class="pl-subtitle" id="pl-confirm-subtitle" hidden aria-hidden="true">
                            Session will be marked <strong>incomplete</strong>.
                        </p>

                        <div class="pl-grid-two" hidden aria-hidden="true">
                            <div class="pl-info-box" hidden aria-hidden="true">
                                <span class="pl-info-label" hidden aria-hidden="true">Current elapsed</span>
                                <strong class="pl-info-value" id="pl-confirm-current-time" hidden aria-hidden="true">00:00:00</strong>
                            </div>

                            <div class="pl-info-box" hidden aria-hidden="true">
                                <span class="pl-info-label" hidden aria-hidden="true">Timer status</span>
                                <strong class="pl-info-value" id="pl-confirm-timer-status" hidden aria-hidden="true">Still counting down</strong>
                            </div>
                        </div>

                        <div class="pl-grid-two" hidden aria-hidden="true">
                            <div class="pl-info-box" hidden aria-hidden="true">
                                <span class="pl-info-label" id="pl-confirm-complete-label" hidden aria-hidden="true">If complete</span>

                                <div class="pl-reward-row" hidden aria-hidden="true">
                                    <span hidden aria-hidden="true">XP</span>
                                    <strong id="pl-confirm-complete-xp" hidden aria-hidden="true">0</strong>
                                </div>

                                <div class="pl-reward-row" hidden aria-hidden="true">
                                    <span hidden aria-hidden="true">Coins</span>
                                    <strong id="pl-confirm-complete-coins" hidden aria-hidden="true">0</strong>
                                </div>
                            </div>

                            <div class="pl-info-box" hidden aria-hidden="true">
                                <span class="pl-info-label" id="pl-confirm-current-label" hidden aria-hidden="true">Current</span>

                                <div class="pl-reward-row" hidden aria-hidden="true">
                                    <span hidden aria-hidden="true">XP</span>
                                    <strong id="pl-confirm-current-xp" hidden aria-hidden="true">0</strong>
                                </div>

                                <div class="pl-reward-row" hidden aria-hidden="true">
                                    <span hidden aria-hidden="true">Coins</span>
                                    <strong id="pl-confirm-current-coins" hidden aria-hidden="true">0</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-stop-confirm-current-xp" hidden>0</p>
                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-stop-confirm-current-coins" hidden>0</p>
                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-stop-confirm-potential-xp" hidden>0</p>
                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-stop-confirm-potential-coins" hidden>0</p>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-keep-going"
                            id="pl-confirm-keep-going"
                            hidden>
                        <span class="pl-button-label">Keep Going</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-stop"
                            id="pl-confirm-stop"
                            hidden>
                        <span class="pl-button-label">Stop Focusing</span>
                    </button>

                    <div class="pl-canvas-item pl-canvas-panel pl-canvas-panel-countup-stop-confirm" id="pl-countup-stop-confirm-panel" hidden></div>

                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-countup-stop-confirm-current-xp" hidden>0</p>
                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-countup-stop-confirm-current-coins" hidden>0</p>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-countup-keep-going"
                            id="pl-countup-confirm-keep-going"
                            hidden>
                        <span class="pl-button-label">Keep Going</span>
                    </button>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-countup-stop"
                            id="pl-countup-confirm-stop"
                            hidden>
                        <span class="pl-button-label">Stop Focusing</span>
                    </button>

                    <div class="pl-panel-dim pl-canvas-item" id="pl-reward-dim" hidden></div>

                    <div class="pl-canvas-item pl-canvas-panel pl-canvas-panel-reward" id="pl-reward-panel" hidden>
                        <p class="pl-eyebrow" hidden aria-hidden="true">Rewards</p>
                        <h2 class="pl-section-title" hidden aria-hidden="true">Rewards</h2>
                        <p class="pl-subtitle" hidden aria-hidden="true">
                            <span id="pl-reward-status-text" hidden aria-hidden="true">Completed</span>
                            <strong id="pl-reward-focus-type" hidden aria-hidden="true">Focus</strong>
                            session for
                            <strong id="pl-reward-duration-text" hidden aria-hidden="true">00:00:00</strong>.
                        </p>

                        <div class="pl-grid-two" hidden aria-hidden="true">
                            <div class="pl-info-box" hidden aria-hidden="true">
                                <span class="pl-info-label" hidden aria-hidden="true">XP</span>
                                <strong class="pl-reward-value-large" id="pl-reward-xp" hidden aria-hidden="true">0</strong>
                            </div>

                            <div class="pl-info-box" hidden aria-hidden="true">
                                <span class="pl-info-label" hidden aria-hidden="true">Coins</span>
                                <strong class="pl-reward-value-large" id="pl-reward-coins" hidden aria-hidden="true">0</strong>
                            </div>
                        </div>
                    </div>

                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-reward-current-xp" hidden>0</p>
                    <p class="pl-canvas-item pl-overlay-value-asset" id="pl-reward-current-coins" hidden>0</p>

                    <button type="button"
                            class="pl-canvas-item pl-canvas-button pl-canvas-button-gotcha"
                            id="pl-reward-close-button"
                            hidden>
                        <span class="pl-button-label">Gotcha!</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* SEGMENT A1 END - Home Canvas Stage Markup *@

@* SEGMENT A2 START - Layout Panel + Script References *@
<aside class="pl-layout-panel" id="pl-layout-panel" hidden aria-label="Layout mode panel">
    <div class="pl-layout-header">
        <strong>Layout Mode</strong>
        <span id="pl-layout-scene-name">Home</span>
    </div>

    <div class="pl-layout-status-stack">
        <span class="pl-field-hint" id="pl-layout-stage-status">Safe UI layer</span>
        <span class="pl-field-hint" id="pl-layout-safe-zone-status">Inside safe zone.</span>
    </div>

    <div class="pl-field pl-layout-diagnostics-field" id="pl-layout-pwa-diagnostics-field">
        <span class="pl-field-label">PWA / Offline Diagnostics</span>
        <span class="pl-field-hint" id="pl-layout-pwa-diagnostics-summary">Waiting for startup diagnostics.</span>
        <pre class="pl-layout-diagnostics-code" id="pl-layout-pwa-diagnostics-body">No diagnostics yet.</pre>
    </div>

    <label class="pl-field">
        <span class="pl-field-label">Mode</span>
        <select class="pl-input" id="pl-layout-editor-mode-select">
            <option value="layout">Layout</option>
            <option value="scene-builder">Scene Builder</option>
        </select>
        <span class="pl-field-hint" id="pl-layout-editor-mode-hint">Layout moves assets. Scene Builder adds assets to scenes and creates text labels.</span>
    </label>

    <div class="pl-field" id="pl-layout-editor-toggle-field">
        <label for="pl-layout-editor-enabled" style="display:flex;align-items:center;gap:0.55rem;cursor:pointer;">
            <input id="pl-layout-editor-enabled" type="checkbox" checked />
            <span class="pl-field-label" style="margin:0;">Enable Layout Mode Editor</span>
        </label>
        <span class="pl-field-hint" id="pl-layout-editor-mode-status">Checked: click assets to select and move them. Unchecked: interact with the app normally.</span>
    </div>

    <label class="pl-field">
        <span class="pl-field-label">Scene</span>
        <select class="pl-input" id="pl-layout-scene-select">
            <option value="home">Home</option>
            <option value="focus-setup">Focus setup</option>
            <option value="focus-manage">Focus manage</option>
            <option value="focus-running">Focus running</option>
            <option value="stop-confirm">Stop confirm</option>
            <option value="countup-stop-confirm">Count up stop confirm</option>
            <option value="reward">Reward</option>
            <option value="app-shell">App shell</option>
        </select>
    </label>

    <label class="pl-field">
        <span class="pl-field-label">State</span>
        <select class="pl-input" id="pl-layout-state-select">
            <option value="base">Base</option>
        </select>
        <span class="pl-field-hint" id="pl-layout-state-status">Base = shared scene layout. Scene-specific states can override visibility.</span>
    </label>

    <label class="pl-field">
        <span class="pl-field-label">Asset</span>
        <select class="pl-input" id="pl-layout-asset-select">
            <option value="home-scene">home-scene</option>
            <option value="home-focus">home-focus</option>
            <option value="home-sleep">home-sleep</option>
        </select>
    </label>

    <label class="pl-field">
        <span class="pl-field-label">Component</span>
        <select class="pl-input" id="pl-layout-component-select">
            <option value="root">Whole Asset</option>
        </select>
        <span class="pl-field-hint" id="pl-layout-component-status">This asset currently has no separate components.</span>
    </label>

    <div class="pl-field" id="pl-layout-art-picker-field" hidden>
        <span class="pl-field-label">Asset PNG</span>
        <button type="button" class="pl-home-action-button" id="pl-layout-art-picker-button">Browse PNG</button>
        <input id="pl-layout-art-picker-input" type="file" accept=".png,image/png" hidden />
        <span class="pl-field-hint" id="pl-layout-art-picker-status">No PNG override selected.</span>
    </div>

    <div class="pl-field" id="pl-layout-state-visibility-field" hidden>
        <label for="pl-layout-state-visible" style="display:flex;align-items:center;gap:0.55rem;cursor:pointer;">
            <input id="pl-layout-state-visible" type="checkbox" checked />
            <span class="pl-field-label" style="margin:0;">Visible in selected state</span>
        </label>
        <span class="pl-field-hint" id="pl-layout-state-visible-status">This asset currently inherits its visibility from the base scene layout.</span>
    </div>

    <div id="pl-layout-scene-builder-panel" hidden>
        <div class="pl-field">
            <span class="pl-field-label">Add Existing Asset To Scene</span>
            <select class="pl-input" id="pl-layout-scene-asset-source-select"></select>
            <div class="pl-layout-actions" style="margin-top:0.75rem;">
                <button type="button" class="pl-home-action-button" id="pl-layout-scene-asset-add">Add Asset To Scene</button>
                <button type="button" class="pl-home-action-button" id="pl-layout-scene-asset-remove">Remove Selected Asset</button>
            </div>
            <span class="pl-field-hint" id="pl-layout-scene-builder-membership-status">Add an existing asset to this scene, or remove the currently selected asset from it.</span>
        </div>

        <div class="pl-field" id="pl-layout-behavior-role-field" hidden>
            <span class="pl-field-label">Selected Asset Behavior</span>
            <select class="pl-input" id="pl-layout-behavior-role-select">
                <option value="none">None</option>
                <option value="open-focus-setup">Open Focus Setup</option>
                <option value="open-focus-manage">Open Focus Manage</option>
                <option value="return-home">Return Home</option>
                <option value="return-focus-setup">Return Focus Setup</option>
                <option value="select-countdown-mode">Select Count Down Mode</option>
                <option value="select-countup-mode">Select Count Up Mode</option>
                <option value="start-focus-session">Start Focus Session</option>
                <option value="toggle-pause-session">Toggle Pause Session</option>
                <option value="stop-focus-session">Stop Focus Session</option>
                <option value="confirm-keep-going">Confirm Keep Going</option>
                <option value="confirm-stop-session">Confirm Stop Session</option>
                <option value="close-reward">Close Reward</option>
            </select>
            <span class="pl-field-hint" id="pl-layout-behavior-role-status">Select an interactive asset in Scene Builder to edit its behavior role.</span>
        </div>

        <div class="pl-field">
            <span class="pl-field-label">Create Text Asset</span>
            <input class="pl-input" id="pl-layout-new-text-asset-key" type="text" maxlength="48" placeholder="focus-setup-mode-label" />
            <input class="pl-input" id="pl-layout-new-text-asset-content" type="text" maxlength="80" placeholder="Count Up" style="margin-top:0.75rem;" />
            <select class="pl-input" id="pl-layout-new-text-asset-preset" style="margin-top:0.75rem;">
                <option value="text-label">Text Label</option>
                <option value="text-title">Text Title</option>
                <option value="text-hint">Text Hint</option>
            </select>
            <div class="pl-layout-actions" style="margin-top:0.75rem;">
                <button type="button" class="pl-home-action-button" id="pl-layout-create-text-asset">Create Text Asset</button>
            </div>
            <span class="pl-field-hint" id="pl-layout-scene-builder-text-status">Creates a reusable text asset and adds it to the selected scene.</span>
        </div>
    </div>

    <div class="pl-field">
        <label class="pl-field-label" for="pl-layout-scale">Scale</label>
        <div class="pl-layout-range-with-number">
            <input class="pl-input" id="pl-layout-scale" type="range" min="20" max="250" step="1" value="100" />
            <input class="pl-input pl-layout-number-input" id="pl-layout-scale-number" type="number" min="20" max="250" step="1" value="100" />
        </div>
        <span class="pl-field-hint" id="pl-layout-scale-value">100%</span>
    </div>

    <div class="pl-field">
        <label class="pl-field-label" for="pl-layout-x">X (px)</label>
        <div class="pl-layout-range-with-number">
            <input class="pl-input" id="pl-layout-x" type="range" min="-300" max="700" step="1" value="0" />
            <input class="pl-input pl-layout-number-input" id="pl-layout-x-number" type="number" min="-300" max="700" step="1" value="0" />
        </div>
        <span class="pl-field-hint" id="pl-layout-x-value">0 px (inside safe zone)</span>
    </div>

    <div class="pl-field">
        <label class="pl-field-label" for="pl-layout-y">Y (px)</label>
        <div class="pl-layout-range-with-number">
            <input class="pl-input" id="pl-layout-y" type="range" min="-300" max="1200" step="1" value="0" />
            <input class="pl-input pl-layout-number-input" id="pl-layout-y-number" type="number" min="-300" max="1200" step="1" value="0" />
        </div>
        <span class="pl-field-hint" id="pl-layout-y-value">0 px (inside safe zone)</span>
    </div>

    <label class="pl-field">
        <span class="pl-field-label">Width (px)</span>
        <input class="pl-input" id="pl-layout-width" type="number" min="20" max="700" step="1" value="170" />
    </label>

    <label class="pl-field">
        <span class="pl-field-label" id="pl-layout-height-label">Height (px)</span>
        <input class="pl-input" id="pl-layout-height" type="number" min="20" max="1200" step="1" value="56" />
        <span class="pl-field-hint" id="pl-layout-height-hint"></span>
    </label>

    <div class="pl-field" id="pl-layout-hit-scale-field" hidden>
        <span class="pl-field-label">Interactable Area Size</span>

        <label class="pl-field-label" for="pl-layout-hit-scale-x" style="display:block;margin-top:0.45rem;">Width scale</label>
        <div class="pl-layout-range-with-number">
            <input class="pl-input" id="pl-layout-hit-scale-x" type="range" min="100" max="200" step="1" value="100" />
            <input class="pl-input pl-layout-number-input" id="pl-layout-hit-scale-x-number" type="number" min="100" max="200" step="1" value="100" />
        </div>

        <label class="pl-field-label" for="pl-layout-hit-scale-y" style="display:block;margin-top:0.75rem;">Height scale</label>
        <div class="pl-layout-range-with-number">
            <input class="pl-input" id="pl-layout-hit-scale-y" type="range" min="100" max="200" step="1" value="100" />
            <input class="pl-input pl-layout-number-input" id="pl-layout-hit-scale-y-number" type="number" min="100" max="200" step="1" value="100" />
        </div>

        <label style="display:flex;align-items:center;gap:0.55rem;cursor:pointer;margin-top:0.8rem;">
            <input id="pl-layout-hit-scale-lock" type="checkbox" checked />
            <span class="pl-field-label" style="margin:0;">Lock width + height together</span>
        </label>

        <span class="pl-field-hint" id="pl-layout-hit-scale-status">100% = exact nib-hit bounds on that axis. 200% = double-size interactable area on that axis.</span>
    </div>

    <div class="pl-layout-actions">
        <button type="button" class="pl-home-action-button" id="pl-layout-save-selected">Save Selected</button>
        <button type="button" class="pl-home-action-button" id="pl-layout-revert-selected">Revert Selected</button>
        <button type="button" class="pl-home-action-button" id="pl-layout-reset-selected">Reset Selected</button>
        <button type="button" class="pl-home-action-button" id="pl-layout-save-default">Save as Default</button>
        <button type="button" class="pl-home-action-button" id="pl-layout-reset-default">Reset to Default</button>
    </div>

    <label class="pl-field">
        <span class="pl-field-label">Copy back into art-skin.css / layout-overrides.json</span>
        <textarea class="pl-input pl-layout-code" id="pl-layout-code" readonly></textarea>
    </label>
</aside>

<form method="post" asp-page-handler="SaveFocus" id="pl-save-form">
    <input type="hidden" asp-for="Input.FocusType" id="pl-save-focus-type" value="@Model.InitialFocusType" />
    <input type="hidden" asp-for="Input.PlannedDurationSeconds" id="pl-save-planned-seconds" value="300" />
    <input type="hidden" asp-for="Input.ElapsedSeconds" id="pl-save-elapsed-seconds" value="0" />
    <input type="hidden" asp-for="Input.TimerMode" id="pl-save-timer-mode" value="countdown" />
    <input type="hidden" asp-for="Input.SaveMode" id="pl-save-mode" value="" />
</form>
<script src="~/js/pl-home-stage.js" asp-append-version="true"></script>
<script src="~/js/pl-viewport-debug.js" asp-append-version="true"></script>
<script src="~/js/pl-offline-store.js" asp-append-version="true"></script>
@section Scripts {
    <script src="~/js/pl-home-canvas.js" asp-append-version="true"></script>
}
@* SEGMENT A2 END - Layout Panel + Script References *@
