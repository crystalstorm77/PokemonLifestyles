<!DOCTYPE html>
<html lang="en">
<head>
    <!-- SEGMENT A START — Layout Shell -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pokemon Lifestyles</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/art-skin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/focus-canvas.css" asp-append-version="true" />
    <!-- SEGMENT A END — Layout Shell -->
</head>
<body>
    <div class="app-shell">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>