<!DOCTYPE html>
<html lang="en">
<head>
    <!-- SEGMENT A START — Layout Head -->
    @{
        var shellThemeColor = "#01ff75";

        try
        {
            var layoutFolderPath = Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
                "Pokemon Lifestyles");

            var layoutFilePath = Path.Combine(layoutFolderPath, "layout-overrides.json");

            if (System.IO.File.Exists(layoutFilePath))
            {
                var rawLayout = System.IO.File.ReadAllText(layoutFilePath);

                if (!string.IsNullOrWhiteSpace(rawLayout))
                {
                    using var document = System.Text.Json.JsonDocument.Parse(rawLayout);

                    if (document.RootElement.ValueKind == System.Text.Json.JsonValueKind.Object &&
                        document.RootElement.TryGetProperty("variables", out var variablesElement) &&
                        variablesElement.ValueKind == System.Text.Json.JsonValueKind.Object)
                    {
                        string? candidate = null;

                        if (variablesElement.TryGetProperty("appEdgeColor", out var appEdgeColorElement) &&
                            appEdgeColorElement.ValueKind == System.Text.Json.JsonValueKind.String)
                        {
                            candidate = appEdgeColorElement.GetString();
                        }
                        else if (variablesElement.TryGetProperty("AppEdgeColor", out var appEdgeColorPascalElement) &&
                                 appEdgeColorPascalElement.ValueKind == System.Text.Json.JsonValueKind.String)
                        {
                            candidate = appEdgeColorPascalElement.GetString();
                        }
                        else if (variablesElement.TryGetProperty("app-edge-color", out var appEdgeColorDashedElement) &&
                                 appEdgeColorDashedElement.ValueKind == System.Text.Json.JsonValueKind.String)
                        {
                            candidate = appEdgeColorDashedElement.GetString();
                        }

                        if (!string.IsNullOrWhiteSpace(candidate) &&
                            System.Text.RegularExpressions.Regex.IsMatch(
                                candidate,
                                "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"))
                        {
                            shellThemeColor = candidate;
                        }
                    }
                }
            }
        }
        catch
        {
        }
    }

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <meta name="apple-mobile-web-app-capable" content="yes" />

    <meta name="mobile-web-app-capable" content="yes" />

    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <meta name="apple-mobile-web-app-title" content="Pokemon Lifestyles" />

    <meta name="application-name" content="Pokemon Lifestyles" />

    <meta name="theme-color" content="@shellThemeColor" />

    <style>
            :root {
                --pl-art-app-edge-color: @shellThemeColor;
            }
    </style>

    <title>@ViewData["Title"] - Pokemon Lifestyles</title>

    <link rel="manifest" href="@Url.Content("~/manifest.json")" />

    <link rel="icon" href="~/favicon.ico" asp-append-version="true" sizes="any" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/art-skin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/focus-canvas.css" asp-append-version="true" />

    <script src="~/js/pl-pwa-boot.js" asp-append-version="true"></script>

    <!-- SEGMENT A END — Layout Head -->
</head>
<body>
    <!-- SEGMENT B START — Layout Body -->

    <div class="app-shell">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- SEGMENT B END — Layout Body -->
</body>
</html>