@page
@model LifestylesWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- SECTION A START — Home Screen + Focus Overlay -->
<div class="pl-screen pl-home-screen"
     id="pl-home-root"
     data-reward-xp-per-minute="@Model.RewardPreviewFocusXpPerMinute"
     data-reward-incomplete-multiplier="@Model.RewardPreviewIncompleteMultiplier"
     data-reward-sleep-multiplier="@Model.RewardPreviewSleepMultiplier"
     data-reward-window-eligible="@Model.RewardWindowEligible.ToString().ToLowerInvariant()"
     data-show-reward-overlay="@Model.ShowRewardOverlay.ToString().ToLowerInvariant()"
     data-reward-focus-type="@Model.RewardFocusType"
     data-reward-duration="@Model.FormatDuration(Model.RewardDurationSeconds)"
     data-reward-completed="@Model.RewardCompleted.ToString().ToLowerInvariant()"
     data-reward-xp="@Model.RewardXp"
     data-reward-coins="@Model.RewardCoins">
    <div class="pl-home-scene-art" aria-hidden="true"></div>

    <section class="pl-card pl-home-card">
        <p class="pl-eyebrow">Pokemon Lifestyles</p>
        <h1 class="pl-title">Home</h1>
        <p class="pl-subtitle">
            Focus now opens as an overlay on this screen instead of navigating away to a separate page.
            We are still building functionality first and art second.
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="pl-success-banner">@Model.StatusMessage</div>
        }
    </section>

    <section class="pl-card pl-dev-card">
        <h2 class="pl-section-title">Saved sessions for this game day</h2>
        <p class="pl-section-note">
            Temporary debug view while we build the real overlay flow.
        </p>

        <div class="pl-info-note">
            <strong>Shared data file</strong>
            <span class="pl-code-path">@Model.DataFilePath</span>
        </div>

        @if (Model.Sessions.Count == 0)
        {
            <p class="pl-empty-state">No sessions saved yet for this game day.</p>
        }
        else
        {
            <div class="pl-session-list">
                @foreach (var session in Model.Sessions)
                {
                    <article class="pl-session-item">
                        <div class="pl-session-top">
                            <strong class="pl-session-type">@session.FocusType</strong>
                            <span class="pl-session-minutes">@Model.FormatDuration(session.DurationSeconds)</span>
                        </div>

                        <div class="pl-session-meta">
                            <span>@session.LoggedAtUtc.ToLocalTime().ToString("ddd d MMM, h:mm tt")</span>
                            <span>@(session.Completed ? "Completed" : "Incomplete")</span>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <nav class="pl-bottom-dock" aria-label="Main actions">
        <button class="pl-dock-button pl-dock-button-active" type="button" id="pl-open-focus-button">
            <span class="pl-dock-label">Focus</span>
        </button>

        <button class="pl-dock-button" type="button" disabled>
            <span class="pl-dock-label">Sleep</span>
            <span class="pl-dock-note">Later</span>
        </button>
    </nav>

    <div class="pl-focus-overlay" id="pl-focus-overlay" hidden aria-hidden="true">
        <div class="pl-focus-overlay-backdrop"></div>

        <div class="pl-focus-shell">
            <div class="pl-focus-shell-art" aria-hidden="true"></div>

            <section class="pl-card pl-focus-panel pl-focus-panel-setup" id="pl-focus-setup-panel">
                <div class="pl-card-header">
                    <button type="button" class="pl-link-button" id="pl-focus-back-button">← Back</button>
                    <span class="pl-badge">Countdown</span>
                </div>

                <p class="pl-eyebrow">Focus Session</p>
                <h2 class="pl-title">Stay with it</h2>
                <p class="pl-subtitle">
                    This opens over the home screen instead of as a separate page.
                    For now, this pass is countdown only.
                </p>

                <div class="pl-mode-grid">
                    <button class="pl-mode-chip pl-mode-chip-active" type="button">
                        <span>Countdown</span>
                        <small>Ready now</small>
                    </button>

                    <button class="pl-mode-chip pl-mode-chip-disabled" type="button" disabled>
                        <span>Count Up</span>
                        <small>Later</small>
                    </button>
                </div>

                <label class="pl-field">
                    <span class="pl-field-label">Focus type</span>
                    <input class="pl-input" id="pl-focus-type-input" type="text" maxlength="40" value="Focus" />
                </label>

                <div class="pl-field">
                    <span class="pl-field-label">Countdown length</span>

                    <div class="pl-duration-card">
                        <strong class="pl-duration-readout" id="pl-duration-readout">5 minutes</strong>

                        <input class="pl-slider"
                               id="pl-duration-slider"
                               type="range"
                               min="5"
                               max="120"
                               step="1"
                               value="5" />

                        <div class="pl-slider-scale">
                            <span>5 min</span>
                            <span>2 hr</span>
                        </div>
                    </div>
                </div>

                <div class="pl-button-stack">
                    <button type="button" class="pl-primary-button pl-art-button pl-button-start" id="pl-start-focus-button">
                        <span class="pl-button-label">Start</span>
                    </button>

                    <button type="button" class="pl-secondary-button pl-art-button pl-button-back" id="pl-close-focus-button">
                        <span class="pl-button-label">Back</span>
                    </button>
                </div>
            </section>

            <section class="pl-card pl-focus-panel pl-focus-panel-run" id="pl-focus-run-panel" hidden>
                <div class="pl-card-header">
                    <button type="button" class="pl-link-button" id="pl-run-home-button">← Home</button>
                    <span class="pl-badge">Countdown</span>
                </div>

                <p class="pl-eyebrow">Focus Session</p>
                <h2 class="pl-title">Stay with it</h2>
                <p class="pl-subtitle">
                    Settings are locked while the session is active.
                </p>

                <div class="pl-run-meta-grid">
                    <div class="pl-run-meta-card">
                        <span class="pl-run-label">Focus type</span>
                        <strong class="pl-run-value" id="pl-run-focus-type">Focus</strong>
                    </div>

                    <div class="pl-run-meta-card">
                        <span class="pl-run-label">Target</span>
                        <strong class="pl-run-value" id="pl-run-target">5 minutes</strong>
                    </div>
                </div>

                <div class="pl-run-timer-shell">
                    <div class="pl-run-timer-caption" id="pl-run-state-label">Time remaining</div>
                    <div class="pl-run-timer" id="pl-run-readout">00:05:00</div>
                    <div class="pl-run-support">
                        Elapsed:
                        <span id="pl-run-elapsed">00:00:00</span>
                    </div>
                </div>

                <div class="pl-progress-track" aria-hidden="true">
                    <div class="pl-progress-fill" id="pl-progress-fill" style="width: 0%;"></div>
                </div>

                <div class="pl-run-actions pl-run-actions-two">
                    <button type="button" class="pl-primary-button pl-art-button pl-button-pause" id="pl-pause-button">
                        <span class="pl-button-label">Pause</span>
                    </button>

                    <button type="button" class="pl-secondary-button pl-art-button pl-button-exit" id="pl-exit-button">
                        <span class="pl-button-label">Cancel</span>
                    </button>
                </div>

                <p class="pl-field-hint" id="pl-run-note">
                    Cancel before 1 minute to discard this session with no save.
                </p>
            </section>

            <div class="pl-run-overlay" id="pl-confirm-overlay" hidden aria-hidden="true">
                <div class="pl-run-overlay-backdrop"></div>

                <div class="pl-run-overlay-card pl-focus-panel-confirm" role="dialog" aria-modal="true" aria-labelledby="pl-confirm-title">
                    <p class="pl-eyebrow">Stop Focusing</p>
                    <h2 class="pl-section-title" id="pl-confirm-title">Are you sure?</h2>
                    <p class="pl-subtitle pl-overlay-subtitle">
                        Session will be marked <strong>incomplete</strong>.
                    </p>

                    <div class="pl-run-meta-grid">
                        <div class="pl-run-meta-card">
                            <span class="pl-run-label">Current elapsed</span>
                            <strong class="pl-run-value" id="pl-confirm-current-time">00:00:00</strong>
                        </div>

                        <div class="pl-run-meta-card">
                            <span class="pl-run-label">Timer status</span>
                            <strong class="pl-run-value" id="pl-confirm-timer-status">Still counting down</strong>
                        </div>
                    </div>

                    <div class="pl-reward-compare-grid">
                        <div class="pl-reward-compare-card">
                            <span class="pl-run-label">If complete</span>

                            <div class="pl-reward-row">
                                <span>XP</span>
                                <strong id="pl-confirm-complete-xp">0</strong>
                            </div>

                            <div class="pl-reward-row">
                                <span>Coins</span>
                                <strong id="pl-confirm-complete-coins">0</strong>
                            </div>
                        </div>

                        <div class="pl-reward-compare-card">
                            <span class="pl-run-label">Current</span>

                            <div class="pl-reward-row">
                                <span>XP</span>
                                <strong id="pl-confirm-current-xp">0</strong>
                            </div>

                            <div class="pl-reward-row">
                                <span>Coins</span>
                                <strong id="pl-confirm-current-coins">0</strong>
                            </div>
                        </div>
                    </div>

                    <div class="pl-run-actions pl-run-actions-two">
                        <button type="button" class="pl-secondary-button pl-art-button pl-button-keep-going" id="pl-confirm-keep-going">
                            <span class="pl-button-label">Keep Going</span>
                        </button>

                        <button type="button" class="pl-primary-button pl-art-button pl-button-stop" id="pl-confirm-stop">
                            <span class="pl-button-label">Stop Focusing</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="pl-run-overlay" id="pl-reward-overlay" hidden aria-hidden="true">
        <div class="pl-run-overlay-backdrop"></div>

        <div class="pl-run-overlay-card pl-reward-overlay-card pl-focus-panel-reward" role="dialog" aria-modal="true" aria-labelledby="pl-reward-title">
            <p class="pl-eyebrow">Rewards</p>
            <h2 class="pl-section-title" id="pl-reward-title">Rewards</h2>
            <p class="pl-subtitle pl-overlay-subtitle">
                <span id="pl-reward-status-text">Completed</span>
                <strong id="pl-reward-focus-type">Focus</strong>
                session for
                <strong id="pl-reward-duration-text">00:00:00</strong>.
            </p>

            <div class="pl-reward-summary-grid">
                <div class="pl-reward-summary-card">
                    <span class="pl-run-label">XP</span>
                    <strong class="pl-reward-value-large" id="pl-reward-xp">0</strong>
                </div>

                <div class="pl-reward-summary-card">
                    <span class="pl-run-label">Coins</span>
                    <strong class="pl-reward-value-large" id="pl-reward-coins">0</strong>
                </div>
            </div>

            <div class="pl-button-stack">
                <button type="button" class="pl-primary-button pl-art-button pl-button-gotcha" id="pl-reward-close-button">
                    <span class="pl-button-label">Gotcha!</span>
                </button>
            </div>
        </div>
    </div>

    <form method="post" asp-page-handler="SaveFocus" id="pl-save-form">
        <input type="hidden" asp-for="Input.FocusType" id="pl-save-focus-type" value="Focus" />
        <input type="hidden" asp-for="Input.PlannedDurationSeconds" id="pl-save-planned-seconds" value="300" />
        <input type="hidden" asp-for="Input.ElapsedSeconds" id="pl-save-elapsed-seconds" value="0" />
        <input type="hidden" asp-for="Input.SaveMode" id="pl-save-mode" value="" />
    </form>

    <aside class="pl-layout-panel" id="pl-layout-panel" hidden aria-label="Layout mode panel">
        <div class="pl-layout-panel-header">
            <strong>Layout Mode</strong>
            <span>Buttons only</span>
        </div>

        <label class="pl-field">
            <span class="pl-field-label">Asset</span>
            <select class="pl-input" id="pl-layout-asset-select">
                <option value="start">start</option>
                <option value="back">back</option>
                <option value="pause">pause</option>
                <option value="exit">exit</option>
                <option value="keep-going">keep-going</option>
                <option value="stop">stop</option>
                <option value="gotcha">gotcha</option>
            </select>
        </label>

        <label class="pl-field">
            <span class="pl-field-label">Scale</span>
            <input class="pl-input" id="pl-layout-scale" type="range" min="40" max="160" step="1" value="100" />
            <span class="pl-field-hint" id="pl-layout-scale-value">100%</span>
        </label>

        <label class="pl-field">
            <span class="pl-field-label">X</span>
            <input class="pl-input" id="pl-layout-x" type="range" min="0" max="100" step="1" value="50" />
            <span class="pl-field-hint" id="pl-layout-x-value">50%</span>
        </label>

        <label class="pl-field">
            <span class="pl-field-label">Y</span>
            <input class="pl-input" id="pl-layout-y" type="range" min="0" max="100" step="1" value="50" />
            <span class="pl-field-hint" id="pl-layout-y-value">50%</span>
        </label>

        <div class="pl-layout-actions">
            <button type="button" class="pl-secondary-button" id="pl-layout-reset-selected">Reset Selected</button>
            <button type="button" class="pl-secondary-button" id="pl-layout-reset-all">Reset All</button>
        </div>

        <label class="pl-field">
            <span class="pl-field-label">Copy back into site.css</span>
            <textarea class="pl-input pl-layout-code" id="pl-layout-code" readonly></textarea>
        </label>
    </aside>
</div>
<!-- SECTION A END — Home Screen + Focus Overlay -->
@section Scripts {
    <!-- SECTION B START — Home Screen Scripts -->
    <script>
                (function () {
                    const homeRoot = document.getElementById("pl-home-root");
                    const focusOverlay = document.getElementById("pl-focus-overlay");
                    const rewardOverlay = document.getElementById("pl-reward-overlay");

                    const openFocusButton = document.getElementById("pl-open-focus-button");
                    const focusBackButton = document.getElementById("pl-focus-back-button");
                    const closeFocusButton = document.getElementById("pl-close-focus-button");
                    const runHomeButton = document.getElementById("pl-run-home-button");

                    const setupPanel = document.getElementById("pl-focus-setup-panel");
                    const runPanel = document.getElementById("pl-focus-run-panel");

                    const focusTypeInput = document.getElementById("pl-focus-type-input");
                    const durationSlider = document.getElementById("pl-duration-slider");
                    const durationReadout = document.getElementById("pl-duration-readout");
                    const startFocusButton = document.getElementById("pl-start-focus-button");

                    const runFocusType = document.getElementById("pl-run-focus-type");
                    const runTarget = document.getElementById("pl-run-target");
                    const runStateLabel = document.getElementById("pl-run-state-label");
                    const runReadout = document.getElementById("pl-run-readout");
                    const runElapsed = document.getElementById("pl-run-elapsed");
                    const progressFill = document.getElementById("pl-progress-fill");
                    const pauseButton = document.getElementById("pl-pause-button");
                    const exitButton = document.getElementById("pl-exit-button");
                    const runNote = document.getElementById("pl-run-note");

                    const confirmOverlay = document.getElementById("pl-confirm-overlay");
                    const confirmCurrentTime = document.getElementById("pl-confirm-current-time");
                    const confirmTimerStatus = document.getElementById("pl-confirm-timer-status");
                    const confirmCompleteXp = document.getElementById("pl-confirm-complete-xp");
                    const confirmCompleteCoins = document.getElementById("pl-confirm-complete-coins");
                    const confirmCurrentXp = document.getElementById("pl-confirm-current-xp");
                    const confirmCurrentCoins = document.getElementById("pl-confirm-current-coins");
                    const confirmKeepGoingButton = document.getElementById("pl-confirm-keep-going");
                    const confirmStopButton = document.getElementById("pl-confirm-stop");

                    const rewardStatusText = document.getElementById("pl-reward-status-text");
                    const rewardFocusType = document.getElementById("pl-reward-focus-type");
                    const rewardDurationText = document.getElementById("pl-reward-duration-text");
                    const rewardXp = document.getElementById("pl-reward-xp");
                    const rewardCoins = document.getElementById("pl-reward-coins");
                    const rewardCloseButton = document.getElementById("pl-reward-close-button");

                    const saveForm = document.getElementById("pl-save-form");
                    const saveFocusType = document.getElementById("pl-save-focus-type");
                    const savePlannedSeconds = document.getElementById("pl-save-planned-seconds");
                    const saveElapsedSeconds = document.getElementById("pl-save-elapsed-seconds");
                    const saveMode = document.getElementById("pl-save-mode");

                    const layoutPanel = document.getElementById("pl-layout-panel");
                    const layoutAssetSelect = document.getElementById("pl-layout-asset-select");
                    const layoutScale = document.getElementById("pl-layout-scale");
                    const layoutX = document.getElementById("pl-layout-x");
                    const layoutY = document.getElementById("pl-layout-y");
                    const layoutScaleValue = document.getElementById("pl-layout-scale-value");
                    const layoutXValue = document.getElementById("pl-layout-x-value");
                    const layoutYValue = document.getElementById("pl-layout-y-value");
                    const layoutResetSelected = document.getElementById("pl-layout-reset-selected");
                    const layoutResetAll = document.getElementById("pl-layout-reset-all");
                    const layoutCode = document.getElementById("pl-layout-code");

                    if (!homeRoot || !focusOverlay || !rewardOverlay || !openFocusButton || !focusBackButton ||
                        !closeFocusButton || !runHomeButton || !setupPanel || !runPanel || !focusTypeInput ||
                        !durationSlider || !durationReadout || !startFocusButton || !runFocusType || !runTarget ||
                        !runStateLabel || !runReadout || !runElapsed || !progressFill || !pauseButton ||
                        !exitButton || !runNote || !confirmOverlay || !confirmCurrentTime || !confirmTimerStatus ||
                        !confirmCompleteXp || !confirmCompleteCoins || !confirmCurrentXp || !confirmCurrentCoins ||
                        !confirmKeepGoingButton || !confirmStopButton || !rewardStatusText || !rewardFocusType ||
                        !rewardDurationText || !rewardXp || !rewardCoins || !rewardCloseButton || !saveForm ||
                        !saveFocusType || !savePlannedSeconds || !saveElapsedSeconds || !saveMode ||
                        !layoutPanel || !layoutAssetSelect || !layoutScale || !layoutX || !layoutY ||
                        !layoutScaleValue || !layoutXValue || !layoutYValue || !layoutResetSelected ||
                        !layoutResetAll || !layoutCode) {
                        return;
                    }

                    const stopThresholdSeconds = 60;
                    const rewardXpPerMinute = Math.max(0, parseFloat(homeRoot.dataset.rewardXpPerMinute || "0") || 0);
                    const rewardIncompleteMultiplier = Math.min(1, Math.max(0, parseFloat(homeRoot.dataset.rewardIncompleteMultiplier || "0.25") || 0.25));
                    const rewardSleepMultiplier = Math.max(1, parseFloat(homeRoot.dataset.rewardSleepMultiplier || "1") || 1);
                    const rewardWindowEligible = String(homeRoot.dataset.rewardWindowEligible || "").toLowerCase() === "true";
                    const shouldShowRewardOverlay = String(homeRoot.dataset.showRewardOverlay || "").toLowerCase() === "true";

                    const layoutModeEnabled = new URL(window.location.href).searchParams.get("layout") === "1";
                    const layoutStorageKey = "pl-layout-mode-v1";

                    const layoutAssets = {
                        "start": "--pl-btn-start",
                        "back": "--pl-btn-back",
                        "pause": "--pl-btn-pause",
                        "exit": "--pl-btn-exit",
                        "keep-going": "--pl-btn-keep-going",
                        "stop": "--pl-btn-stop",
                        "gotcha": "--pl-btn-gotcha"
                    };

                    let plannedSeconds = 300;
                    let startedAtMs = 0;
                    let pausedElapsedSeconds = 0;
                    let isRunning = false;
                    let isPaused = false;
                    let isSubmitting = false;
                    let isConfirmOpen = false;
                    let completionTonePlayed = false;

                    function setButtonLabel(button, text) {
                        if (!button) {
                            return;
                        }

                        let label = button.querySelector(".pl-button-label");

                        if (!label) {
                            label = document.createElement("span");
                            label.className = "pl-button-label";
                            button.replaceChildren(label);
                        }

                        label.textContent = text;
                    }

                    function formatClock(totalSeconds) {
                        totalSeconds = Math.max(0, Math.floor(totalSeconds));

                        const hours = Math.floor(totalSeconds / 3600);
                        const minutes = Math.floor((totalSeconds % 3600) / 60);
                        const seconds = totalSeconds % 60;

                        return `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
                    }

                    function formatDurationSelection(totalMinutes) {
                        totalMinutes = Math.max(5, Math.min(120, totalMinutes));

                        const hours = Math.floor(totalMinutes / 60);
                        const minutes = totalMinutes % 60;

                        if (hours === 0) {
                            return `${totalMinutes} minutes`;
                        }

                        if (minutes === 0) {
                            return hours === 1 ? "1 hour" : `${hours} hours`;
                        }

                        return hours === 1
                            ? `1 hour ${minutes} minutes`
                            : `${hours} hours ${minutes} minutes`;
                    }

                    function calculateRewardPreview(durationSeconds, completed) {
                        const rewardMinutes = Math.floor(Math.max(0, durationSeconds) / 60);

                        if (!rewardWindowEligible || rewardMinutes <= 0) {
                            return { xp: 0, coins: 0 };
                        }

                        const xpCompletionMultiplier = completed ? 1.0 : rewardIncompleteMultiplier;
                        const coinCompletionMultiplier = completed ? 1.0 : 0.25;

                        return {
                            xp: Math.floor(rewardMinutes * rewardXpPerMinute * xpCompletionMultiplier * rewardSleepMultiplier),
                            coins: Math.floor(rewardMinutes * coinCompletionMultiplier * rewardSleepMultiplier)
                        };
                    }

                    function updateDurationReadout() {
                        const totalMinutes = parseInt(durationSlider.value || "5", 10);
                        durationReadout.textContent = formatDurationSelection(totalMinutes);
                    }

                    function showSetupPanel() {
                        setupPanel.hidden = false;
                        runPanel.hidden = true;
                    }

                    function showRunPanel() {
                        setupPanel.hidden = true;
                        runPanel.hidden = false;
                    }

                    function openFocusOverlay() {
                        focusOverlay.hidden = false;
                        focusOverlay.setAttribute("aria-hidden", "false");
                        closeConfirmOverlay();
                        showSetupPanel();
                        updateDurationReadout();
                    }

                    function closeFocusOverlay() {
                        focusOverlay.hidden = true;
                        focusOverlay.setAttribute("aria-hidden", "true");
                        closeConfirmOverlay();
                        resetRunState();
                    }

                    function openRewardOverlay() {
                        rewardOverlay.hidden = false;
                        rewardOverlay.setAttribute("aria-hidden", "false");
                    }

                    function closeRewardOverlay() {
                        rewardOverlay.hidden = true;
                        rewardOverlay.setAttribute("aria-hidden", "true");
                    }

                    function hydrateRewardOverlayFromDataset() {
                        rewardStatusText.textContent = String(homeRoot.dataset.rewardCompleted || "").toLowerCase() === "true"
                            ? "Completed"
                            : "Incomplete";

                        rewardFocusType.textContent = homeRoot.dataset.rewardFocusType || "Focus";
                        rewardDurationText.textContent = homeRoot.dataset.rewardDuration || "00:00:00";
                        rewardXp.textContent = homeRoot.dataset.rewardXp || "0";
                        rewardCoins.textContent = homeRoot.dataset.rewardCoins || "0";
                    }

                    function resetRunState() {
                        isRunning = false;
                        isPaused = false;
                        isSubmitting = false;
                        isConfirmOpen = false;
                        completionTonePlayed = false;
                        pausedElapsedSeconds = 0;
                        startedAtMs = 0;

                        setButtonLabel(pauseButton, "Pause");
                        setButtonLabel(exitButton, "Cancel");
                        exitButton.classList.remove("pl-stop-button-armed");
                        runStateLabel.textContent = "Time remaining";
                        runReadout.textContent = "00:05:00";
                        runElapsed.textContent = "00:00:00";
                        progressFill.style.width = "0%";
                        runNote.textContent = "Cancel before 1 minute to discard this session with no save.";
                        showSetupPanel();
                    }

                    function getElapsedSeconds() {
                        if (!isRunning) {
                            return 0;
                        }

                        if (isPaused) {
                            return Math.min(plannedSeconds, pausedElapsedSeconds);
                        }

                        const liveElapsed = Math.floor((Date.now() - startedAtMs) / 1000);
                        return Math.min(plannedSeconds, Math.max(0, liveElapsed));
                    }

                    function setButtonsDisabled(isDisabled) {
                        pauseButton.disabled = isDisabled;
                        exitButton.disabled = isDisabled;
                        confirmKeepGoingButton.disabled = isDisabled;
                        confirmStopButton.disabled = isDisabled;
                        startFocusButton.disabled = isDisabled;
                    }

                    function openConfirmOverlay() {
                        isConfirmOpen = true;
                        confirmOverlay.hidden = false;
                        confirmOverlay.setAttribute("aria-hidden", "false");
                        updateConfirmOverlay(getElapsedSeconds());
                    }

                    function closeConfirmOverlay() {
                        isConfirmOpen = false;
                        confirmOverlay.hidden = true;
                        confirmOverlay.setAttribute("aria-hidden", "true");
                    }

                    function updateConfirmOverlay(elapsedSeconds) {
                        const completePreview = calculateRewardPreview(plannedSeconds, true);
                        const currentPreview = calculateRewardPreview(elapsedSeconds, false);

                        confirmCurrentTime.textContent = formatClock(elapsedSeconds);
                        confirmTimerStatus.textContent = isPaused ? "Paused" : "Still counting down";
                        confirmCompleteXp.textContent = String(completePreview.xp);
                        confirmCompleteCoins.textContent = String(completePreview.coins);
                        confirmCurrentXp.textContent = String(currentPreview.xp);
                        confirmCurrentCoins.textContent = String(currentPreview.coins);
                    }

                    function playCompletionTone() {
                        if (completionTonePlayed) {
                            return;
                        }

                        completionTonePlayed = true;

                        try {
                            const AudioContextClass = window.AudioContext || window.webkitAudioContext;

                            if (!AudioContextClass) {
                                return;
                            }

                            const audioContext = new AudioContextClass();
                            const oscillator = audioContext.createOscillator();
                            const gainNode = audioContext.createGain();

                            oscillator.type = "sine";
                            oscillator.frequency.value = 880;

                            gainNode.gain.setValueAtTime(0.0001, audioContext.currentTime);
                            gainNode.gain.exponentialRampToValueAtTime(0.08, audioContext.currentTime + 0.02);
                            gainNode.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.35);

                            oscillator.connect(gainNode);
                            gainNode.connect(audioContext.destination);

                            oscillator.start();
                            oscillator.stop(audioContext.currentTime + 0.36);
                        } catch {
                        }
                    }

                    function submitSave(mode) {
                        if (isSubmitting) {
                            return;
                        }

                        const elapsedSeconds = mode === "complete"
                            ? plannedSeconds
                            : getElapsedSeconds();

                        if (elapsedSeconds <= 0) {
                            return;
                        }

                        isSubmitting = true;
                        saveFocusType.value = (focusTypeInput.value || "Focus").trim() || "Focus";
                        savePlannedSeconds.value = String(plannedSeconds);
                        saveElapsedSeconds.value = String(elapsedSeconds);
                        saveMode.value = mode;
                        closeConfirmOverlay();
                        setButtonsDisabled(true);
                        saveForm.submit();
                    }

                    function updateExitButton(elapsedSeconds) {
                        if (elapsedSeconds >= stopThresholdSeconds) {
                            setButtonLabel(exitButton, "Stop Focusing");
                            exitButton.classList.add("pl-stop-button-armed");
                            return;
                        }

                        setButtonLabel(exitButton, "Cancel");
                        exitButton.classList.remove("pl-stop-button-armed");
                    }

                    function updateUi() {
                        if (!isRunning) {
                            return;
                        }

                        const elapsedSeconds = getElapsedSeconds();
                        const remainingSeconds = Math.max(0, plannedSeconds - elapsedSeconds);
                        const progressPercent = plannedSeconds <= 0
                            ? 0
                            : (elapsedSeconds / plannedSeconds) * 100;

                        runReadout.textContent = formatClock(remainingSeconds);
                        runElapsed.textContent = formatClock(elapsedSeconds);
                        progressFill.style.width = `${Math.max(0, Math.min(100, progressPercent))}%`;

                        updateExitButton(elapsedSeconds);

                        if (isConfirmOpen) {
                            updateConfirmOverlay(elapsedSeconds);
                        }

                        if (isPaused) {
                            runStateLabel.textContent = "Paused";
                            setButtonLabel(pauseButton, "Keep Going?");
                            runNote.textContent = elapsedSeconds >= stopThresholdSeconds
                                ? "Session paused. You can keep going, or stop focusing and save the current incomplete session."
                                : "Session paused. Cancel before 1 minute to discard this session with no save.";
                        } else {
                            runStateLabel.textContent = "Time remaining";
                            setButtonLabel(pauseButton, "Pause");
                            runNote.textContent = elapsedSeconds >= stopThresholdSeconds
                                ? "You have reached 1 minute. Stopping now will save the current session as incomplete."
                                : "Cancel before 1 minute to discard this session with no save.";
                        }

                        if (remainingSeconds <= 0 && !isSubmitting) {
                            playCompletionTone();
                            submitSave("complete");
                        }
                    }

                    function getLayoutVarName(assetKey, suffix) {
                        return `${layoutAssets[assetKey]}-${suffix}`;
                    }

                    function readPercentVar(assetKey, suffix, fallbackValue) {
                        const style = getComputedStyle(homeRoot);
                        const raw = style.getPropertyValue(getLayoutVarName(assetKey, suffix)).trim();

                        if (!raw) {
                            return fallbackValue;
                        }

                        return parseFloat(raw.replace("%", "")) || fallbackValue;
                    }

                    function writePercentVar(assetKey, suffix, value) {
                        homeRoot.style.setProperty(getLayoutVarName(assetKey, suffix), `${value}%`);
                    }

                    function getStoredLayoutState() {
                        try {
                            const raw = localStorage.getItem(layoutStorageKey);
                            return raw ? JSON.parse(raw) : {};
                        } catch {
                            return {};
                        }
                    }

                    function saveLayoutState(state) {
                        try {
                            localStorage.setItem(layoutStorageKey, JSON.stringify(state));
                        } catch {
                        }
                    }

                    function applyStoredLayoutState() {
                        const state = getStoredLayoutState();

                        Object.keys(layoutAssets).forEach(assetKey => {
                            const assetState = state[assetKey];
                            if (!assetState) {
                                return;
                            }

                            writePercentVar(assetKey, "scale", assetState.scale);
                            writePercentVar(assetKey, "x", assetState.x);
                            writePercentVar(assetKey, "y", assetState.y);
                        });
                    }

                    function updateLayoutCodePreview(assetKey, scale, x, y) {
                        const prefix = layoutAssets[assetKey];
                        layoutCode.value =
        `${prefix}-scale: ${scale}%;
        ${prefix}-x: ${x}%;
        ${prefix}-y: ${y}%;`;
                    }

                    function hydrateLayoutControls() {
                        const assetKey = layoutAssetSelect.value;
                        const scale = Math.round(readPercentVar(assetKey, "scale", 100));
                        const x = Math.round(readPercentVar(assetKey, "x", 50));
                        const y = Math.round(readPercentVar(assetKey, "y", 50));

                        layoutScale.value = String(scale);
                        layoutX.value = String(x);
                        layoutY.value = String(y);

                        layoutScaleValue.textContent = `${scale}%`;
                        layoutXValue.textContent = `${x}%`;
                        layoutYValue.textContent = `${y}%`;

                        updateLayoutCodePreview(assetKey, scale, x, y);
                    }

                    function pushLayoutControlValues() {
                        const assetKey = layoutAssetSelect.value;
                        const scale = parseInt(layoutScale.value || "100", 10);
                        const x = parseInt(layoutX.value || "50", 10);
                        const y = parseInt(layoutY.value || "50", 10);

                        writePercentVar(assetKey, "scale", scale);
                        writePercentVar(assetKey, "x", x);
                        writePercentVar(assetKey, "y", y);

                        const state = getStoredLayoutState();
                        state[assetKey] = { scale, x, y };
                        saveLayoutState(state);

                        layoutScaleValue.textContent = `${scale}%`;
                        layoutXValue.textContent = `${x}%`;
                        layoutYValue.textContent = `${y}%`;

                        updateLayoutCodePreview(assetKey, scale, x, y);
                    }

                    function resetSelectedLayoutAsset() {
                        const assetKey = layoutAssetSelect.value;

                        writePercentVar(assetKey, "scale", 100);
                        writePercentVar(assetKey, "x", 50);
                        writePercentVar(assetKey, "y", 50);

                        const state = getStoredLayoutState();
                        state[assetKey] = { scale: 100, x: 50, y: 50 };
                        saveLayoutState(state);

                        hydrateLayoutControls();
                    }

                    function resetAllLayoutAssets() {
                        Object.keys(layoutAssets).forEach(assetKey => {
                            writePercentVar(assetKey, "scale", 100);
                            writePercentVar(assetKey, "x", 50);
                            writePercentVar(assetKey, "y", 50);
                        });

                        saveLayoutState({});
                        hydrateLayoutControls();
                    }

                    openFocusButton.addEventListener("click", function () {
                        closeRewardOverlay();
                        openFocusOverlay();
                    });

                    focusBackButton.addEventListener("click", function () {
                        closeFocusOverlay();
                    });

                    closeFocusButton.addEventListener("click", function () {
                        closeFocusOverlay();
                    });

                    runHomeButton.addEventListener("click", function () {
                        closeFocusOverlay();
                    });

                    durationSlider.addEventListener("input", updateDurationReadout);

                    startFocusButton.addEventListener("click", function () {
                        if (isSubmitting) {
                            return;
                        }

                        const focusType = (focusTypeInput.value || "").trim() || "Focus";
                        const durationMinutes = parseInt(durationSlider.value || "5", 10);

                        plannedSeconds = Math.max(300, Math.min(7200, durationMinutes * 60));
                        startedAtMs = Date.now();
                        pausedElapsedSeconds = 0;
                        isRunning = true;
                        isPaused = false;
                        isSubmitting = false;
                        isConfirmOpen = false;
                        completionTonePlayed = false;

                        runFocusType.textContent = focusType;
                        runTarget.textContent = formatDurationSelection(durationMinutes);

                        showRunPanel();
                        updateUi();
                    });

                    pauseButton.addEventListener("click", function () {
                        if (!isRunning || isSubmitting || isConfirmOpen) {
                            return;
                        }

                        if (!isPaused) {
                            pausedElapsedSeconds = getElapsedSeconds();
                            isPaused = true;
                            updateUi();
                            return;
                        }

                        startedAtMs = Date.now() - (pausedElapsedSeconds * 1000);
                        isPaused = false;
                        updateUi();
                    });

                    exitButton.addEventListener("click", function () {
                        if (!isRunning || isSubmitting) {
                            return;
                        }

                        const elapsedSeconds = getElapsedSeconds();

                        if (elapsedSeconds < stopThresholdSeconds) {
                            closeFocusOverlay();
                            return;
                        }

                        openConfirmOverlay();
                    });

                    confirmKeepGoingButton.addEventListener("click", function () {
                        if (isSubmitting) {
                            return;
                        }

                        closeConfirmOverlay();
                    });

                    confirmStopButton.addEventListener("click", function () {
                        if (isSubmitting) {
                            return;
                        }

                        submitSave("stop");
                    });

                    rewardCloseButton.addEventListener("click", function () {
                        window.location.href = "/Index";
                    });

                    document.addEventListener("keydown", function (event) {
                        if (event.key === "Escape" && isConfirmOpen && !isSubmitting) {
                            closeConfirmOverlay();
                        }
                    });

                    if (layoutModeEnabled) {
                        applyStoredLayoutState();
                        layoutPanel.hidden = false;

                        layoutAssetSelect.addEventListener("change", hydrateLayoutControls);
                        layoutScale.addEventListener("input", pushLayoutControlValues);
                        layoutX.addEventListener("input", pushLayoutControlValues);
                        layoutY.addEventListener("input", pushLayoutControlValues);
                        layoutResetSelected.addEventListener("click", resetSelectedLayoutAsset);
                        layoutResetAll.addEventListener("click", resetAllLayoutAssets);

                        hydrateLayoutControls();
                    }

                    updateDurationReadout();

                    if (shouldShowRewardOverlay) {
                        hydrateRewardOverlayFromDataset();
                        openRewardOverlay();
                    }

                    window.setInterval(updateUi, 250);
                })();
    </script>
    <!-- SECTION B END — Home Screen Scripts -->
}