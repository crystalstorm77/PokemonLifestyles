@page
@model LifestylesWeb.Pages.Focus.FocusIndexModel
@{
    ViewData["Title"] = "Focus Setup";
}

@* SEGMENT A START - Focus Setup Markup *@
<div class="pl-screen">
    <div class="pl-stack">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="pl-status-toast">@Model.StatusMessage</div>
        }

        <section class="pl-card">
            <div class="pl-card-header">
                <a class="pl-link-button" asp-page="/PagesIndex">← Home</a>
                <span class="pl-badge">Legacy Focus Route</span>
            </div>

            <p class="pl-eyebrow">Focus Setup</p>
            <h1 class="pl-title">Start a focus session</h1>
            <p class="pl-subtitle">
                This page keeps the older standalone focus flow available while the main home canvas continues to live on the home page.
            </p>

            <form method="post" asp-page-handler="Start" class="pl-stack" novalidate>
                <div asp-validation-summary="ModelOnly" class="pl-field-hint"></div>

                <label class="pl-field">
                    <span class="pl-field-label">Focus type</span>
                    <input asp-for="Input.FocusType" class="pl-input" maxlength="40" />
                    <span asp-validation-for="Input.FocusType" class="pl-field-hint"></span>
                </label>

                <label class="pl-field">
                    <span class="pl-field-label">Duration (minutes)</span>
                    <input asp-for="Input.DurationMinutes" class="pl-input" type="number" min="5" max="120" step="1" />
                    <span class="pl-field-hint">
                        Current selection: @Model.FormatDurationSelection(Model.Input.DurationMinutes)
                    </span>
                    <span asp-validation-for="Input.DurationMinutes" class="pl-field-hint"></span>
                </label>

                <div class="pl-run-actions pl-run-actions-two">
                    <button type="submit" class="pl-primary-button">Start Focus Timer</button>
                    <a class="pl-secondary-button" asp-page="/PagesIndex">Back Home</a>
                </div>
            </form>
        </section>

        <section class="pl-card">
            <p class="pl-eyebrow">Today</p>
            <h2 class="pl-section-title">Focus sessions for @Model.CurrentGameDayText</h2>

            @if (Model.Sessions.Count == 0)
            {
                <p class="pl-subtitle">No focus sessions have been logged for this game day yet.</p>
            }
            else
            {
                <div class="pl-stack">
                    @foreach (var session in Model.Sessions.OrderByDescending(x => x.LoggedAtUtc))
                    {
                        <div class="pl-info-box">
                            <div class="pl-reward-row">
                                <span>@session.FocusType</span>
                                <strong>@Model.FormatDuration(session.DurationSeconds)</strong>
                            </div>

                            <div class="pl-reward-row">
                                <span>Status</span>
                                <strong>@(session.Completed ? "Completed" : "Incomplete")</strong>
                            </div>

                            <div class="pl-reward-row">
                                <span>Logged</span>
                                <strong>@session.LoggedAtUtc.ToLocalTime().ToString("HH:mm")</strong>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="pl-card">
            <p class="pl-eyebrow">Debug</p>
            <h2 class="pl-section-title">Data file</h2>
            <p class="pl-subtitle">@Model.DataFilePath</p>
        </section>
    </div>
</div>
@* SEGMENT A END - Focus Setup Markup *@

@* SEGMENT B START - Focus Setup Scripts *@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@* SEGMENT B END - Focus Setup Scripts *@