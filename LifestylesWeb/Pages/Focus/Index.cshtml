@page
@model LifestylesWeb.Pages.Focus.IndexModel
@{
    ViewData["Title"] = "Focus";
}

<!-- SECTION A START — Focus Entry Screen -->
<div class="pl-screen">
    <div class="pl-stack">
        <section class="pl-card">
            <div class="pl-card-header">
                <a class="pl-link-button" asp-page="/Index">← Home</a>
                <span class="pl-badge">Countdown first</span>
            </div>

            <h1 class="pl-title">Focus Setup</h1>
            <p class="pl-subtitle">
                This is the first real timer flow for the web app.
                For this step, we are doing countdown only. Count up comes next.
            </p>

            <div class="pl-info-note">
                <strong>Shared data file</strong>
                <span class="pl-code-path">@Model.DataFilePath</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="pl-success-banner">@Model.StatusMessage</div>
            }

            <form method="post" asp-page-handler="Start" class="pl-form-stack">
                <div asp-validation-summary="ModelOnly" class="pl-validation-summary"></div>

                <div class="pl-mode-grid">
                    <button class="pl-mode-chip pl-mode-chip-active" type="button">
                        <span>Countdown</span>
                        <small>Ready now</small>
                    </button>

                    <button class="pl-mode-chip pl-mode-chip-disabled" type="button" disabled>
                        <span>Count Up</span>
                        <small>Later</small>
                    </button>
                </div>

                <label class="pl-field">
                    <span class="pl-field-label">Focus type</span>
                    <input asp-for="Input.FocusType" class="pl-input" placeholder="Draw, Music, Study..." />
                    <span asp-validation-for="Input.FocusType" class="pl-field-error"></span>
                </label>

                <div class="pl-field">
                    <span class="pl-field-label">Countdown length</span>

                    <div class="pl-duration-card">
                        <strong class="pl-duration-readout" id="pl-duration-readout">
                            @Model.FormatDurationSelection(Model.Input.DurationMinutes)
                        </strong>

                        <input asp-for="Input.DurationMinutes"
                               class="pl-slider"
                               id="pl-duration-slider"
                               type="range"
                               min="5"
                               max="120"
                               step="1" />

                        <div class="pl-slider-scale">
                            <span>5 min</span>
                            <span>2 hr</span>
                        </div>
                    </div>

                    <span class="pl-field-hint">
                        The live timer will save the duration from the actual running session, not from a manual seconds box.
                    </span>
                    <span asp-validation-for="Input.DurationMinutes" class="pl-field-error"></span>
                </div>

                <div class="pl-button-stack">
                    <button type="submit" class="pl-primary-button">Start Focus</button>
                    <a class="pl-secondary-button" asp-page="/Index">Back</a>
                </div>
            </form>
        </section>

        <section class="pl-card">
            <h2 class="pl-section-title">Sessions for this game day</h2>
            <p class="pl-section-note">
                Completed countdowns and early stops will both appear here.
            </p>

            @if (Model.Sessions.Count == 0)
            {
                <p class="pl-empty-state">No sessions saved yet for this game day.</p>
            }
            else
            {
                <div class="pl-session-list">
                    @foreach (var session in Model.Sessions)
                    {
                        <article class="pl-session-item">
                            <div class="pl-session-top">
                                <strong class="pl-session-type">@session.FocusType</strong>
                                <span class="pl-session-minutes">@Model.FormatDuration(session.DurationSeconds)</span>
                            </div>

                            <div class="pl-session-meta">
                                <span>@session.LoggedAtUtc.ToLocalTime().ToString("ddd d MMM, h:mm tt")</span>
                                <span>@(session.Completed ? "Completed" : "Incomplete")</span>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</div>
<!-- SECTION A END — Focus Entry Screen -->
@section Scripts {
    <!-- SECTION B START — Validation Scripts -->
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const slider = document.getElementById("pl-duration-slider");
            const readout = document.getElementById("pl-duration-readout");

            if (!slider || !readout) {
                return;
            }

            function formatDuration(totalMinutes) {
                totalMinutes = Math.max(5, Math.min(120, totalMinutes));

                const hours = Math.floor(totalMinutes / 60);
                const minutes = totalMinutes % 60;

                if (hours === 0) {
                    return `${totalMinutes} minutes`;
                }

                if (minutes === 0) {
                    return hours === 1 ? "1 hour" : `${hours} hours`;
                }

                return hours === 1
                    ? `1 hour ${minutes} minutes`
                    : `${hours} hours ${minutes} minutes`;
            }

            function updateReadout() {
                const totalMinutes = parseInt(slider.value || "25", 10);
                readout.textContent = formatDuration(totalMinutes);
            }

            slider.addEventListener("input", updateReadout);
            updateReadout();
        })();
    </script>
    <!-- SECTION B END — Validation Scripts -->
}
}