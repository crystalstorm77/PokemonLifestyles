@page
@model LifestylesWeb.Pages.Focus.RunModel
@{
    ViewData["Title"] = "Focus Timer";
}

<!-- SECTION A START — Countdown Run Screen -->
<div class="pl-screen">
    <div class="pl-stack">
        <section class="pl-card pl-run-card" id="pl-run-root" data-planned-seconds="@Model.PlannedDurationSeconds">
            <div class="pl-card-header">
                <a class="pl-link-button" asp-page="/Focus/Index">← Setup</a>
                <span class="pl-badge">Countdown</span>
            </div>

            <p class="pl-eyebrow">Focus Session</p>
            <h1 class="pl-title">Stay with it</h1>
            <p class="pl-subtitle">
                This first timer screen saves the duration from the live timer itself.
                If you stop early, it saves exactly what the timer was showing at that moment.
            </p>

            <div class="pl-run-meta-grid">
                <div class="pl-run-meta-card">
                    <span class="pl-run-label">Focus type</span>
                    <strong class="pl-run-value">@Model.FocusType</strong>
                </div>

                <div class="pl-run-meta-card">
                    <span class="pl-run-label">Target</span>
                    <strong class="pl-run-value">@Model.TargetDurationText</strong>
                </div>
            </div>

            <div class="pl-run-timer-shell">
                <div class="pl-run-timer-caption" id="pl-run-state-label">Time remaining</div>
                <div class="pl-run-timer" id="pl-run-readout">@Model.InitialRemainingText</div>
                <div class="pl-run-support">
                    Elapsed:
                    <span id="pl-run-elapsed">@Model.InitialElapsedText</span>
                </div>
            </div>

            <div class="pl-progress-track" aria-hidden="true">
                <div class="pl-progress-fill" id="pl-progress-fill" style="width: 0%;"></div>
            </div>

            <div class="pl-run-actions">
                <button type="button" class="pl-primary-button" id="pl-pause-button">Pause</button>
                <button type="button" class="pl-secondary-button" id="pl-stop-button">End &amp; Save</button>
                <button type="button" class="pl-danger-button" id="pl-cancel-button">Discard</button>
            </div>

            <p class="pl-field-hint" id="pl-run-note">
                When the timer reaches zero, it will save automatically as a completed session.
            </p>

            <form method="post" asp-page-handler="Save" id="pl-save-form">
                <input type="hidden" asp-for="Input.FocusType" value="@Model.FocusType" />
                <input type="hidden" asp-for="Input.PlannedDurationSeconds" value="@Model.PlannedDurationSeconds" />
                <input type="hidden" asp-for="Input.ElapsedSeconds" id="pl-elapsed-seconds" value="0" />
                <input type="hidden" asp-for="Input.SaveMode" id="pl-save-mode" value="" />
            </form>
        </section>
    </div>
</div>
<!-- SECTION A START — Countdown Run Screen -->
<div class="pl-screen">
    <div class="pl-stack">
        <section class="pl-card pl-run-card"
                 id="pl-run-root"
                 data-planned-seconds="@Model.PlannedDurationSeconds"
                 data-stop-threshold-seconds="@Model.StopThresholdSeconds"
                 data-stop-threshold-text="@Model.StopThresholdText">
            <div class="pl-card-header">
                <a class="pl-link-button" asp-page="/Focus/Index">← Setup</a>
                <span class="pl-badge">Countdown</span>
            </div>

            <p class="pl-eyebrow">Focus Session</p>
            <h1 class="pl-title">Stay with it</h1>
            <p class="pl-subtitle">
                This pass focuses on the real countdown behaviour:
                pause, keep going, cancel, stop focusing, and the custom confirm overlay.
            </p>

            <div class="pl-run-meta-grid">
                <div class="pl-run-meta-card">
                    <span class="pl-run-label">Focus type</span>
                    <strong class="pl-run-value">@Model.FocusType</strong>
                </div>

                <div class="pl-run-meta-card">
                    <span class="pl-run-label">Target</span>
                    <strong class="pl-run-value">@Model.TargetDurationText</strong>
                </div>
            </div>

            <div class="pl-run-timer-shell">
                <div class="pl-run-timer-caption" id="pl-run-state-label">Time remaining</div>
                <div class="pl-run-timer" id="pl-run-readout">@Model.InitialRemainingText</div>
                <div class="pl-run-support">
                    Elapsed:
                    <span id="pl-run-elapsed">@Model.InitialElapsedText</span>
                </div>
            </div>

            <div class="pl-progress-track" aria-hidden="true">
                <div class="pl-progress-fill" id="pl-progress-fill" style="width: 0%;"></div>
            </div>

            <div class="pl-run-actions pl-run-actions-two">
                <button type="button" class="pl-primary-button" id="pl-pause-button">Pause</button>
                <button type="button" class="pl-secondary-button" id="pl-exit-button">Cancel</button>
            </div>

            <p class="pl-field-hint" id="pl-run-note">
                Cancel before @Model.StopThresholdText to discard this session with no save.
            </p>

            <div class="pl-run-overlay" id="pl-confirm-overlay" hidden aria-hidden="true">
                <div class="pl-run-overlay-backdrop"></div>

                <div class="pl-run-overlay-card" role="dialog" aria-modal="true" aria-labelledby="pl-confirm-title">
                    <p class="pl-eyebrow">Stop Focusing</p>
                    <h2 class="pl-section-title" id="pl-confirm-title">Are you sure?</h2>
                    <p class="pl-subtitle pl-overlay-subtitle">
                        Session will be marked <strong>incomplete</strong>.
                    </p>

                    <div class="pl-run-meta-grid">
                        <div class="pl-run-meta-card">
                            <span class="pl-run-label">Current elapsed</span>
                            <strong class="pl-run-value" id="pl-confirm-current-time">00:00:00</strong>
                        </div>

                        <div class="pl-run-meta-card">
                            <span class="pl-run-label">Timer status</span>
                            <strong class="pl-run-value" id="pl-confirm-timer-status">Still counting down</strong>
                        </div>
                    </div>

                    <p class="pl-field-hint">
                        Rewards preview and the dedicated rewards screen come in the next pass.
                    </p>

                    <div class="pl-run-actions pl-run-actions-two">
                        <button type="button" class="pl-secondary-button" id="pl-confirm-keep-going">Keep Going</button>
                        <button type="button" class="pl-primary-button" id="pl-confirm-stop">Stop Focusing</button>
                    </div>
                </div>
            </div>

            <form method="post" asp-page-handler="Save" id="pl-save-form">
                <input type="hidden" asp-for="Input.FocusType" value="@Model.FocusType" />
                <input type="hidden" asp-for="Input.PlannedDurationSeconds" value="@Model.PlannedDurationSeconds" />
                <input type="hidden" asp-for="Input.ElapsedSeconds" id="pl-elapsed-seconds" value="0" />
                <input type="hidden" asp-for="Input.SaveMode" id="pl-save-mode" value="" />
            </form>
        </section>
    </div>
</div>
<!-- SECTION A END — Countdown Run Screen -->
@section Scripts {
    <!-- SECTION B START — Countdown Timer Script -->
    <script>
        (function () {
            const root = document.getElementById("pl-run-root");
            const readout = document.getElementById("pl-run-readout");
            const elapsedText = document.getElementById("pl-run-elapsed");
            const stateLabel = document.getElementById("pl-run-state-label");
            const note = document.getElementById("pl-run-note");
            const progressFill = document.getElementById("pl-progress-fill");
            const pauseButton = document.getElementById("pl-pause-button");
            const exitButton = document.getElementById("pl-exit-button");

            const confirmOverlay = document.getElementById("pl-confirm-overlay");
            const confirmCurrentTime = document.getElementById("pl-confirm-current-time");
            const confirmTimerStatus = document.getElementById("pl-confirm-timer-status");
            const confirmKeepGoingButton = document.getElementById("pl-confirm-keep-going");
            const confirmStopButton = document.getElementById("pl-confirm-stop");

            const saveForm = document.getElementById("pl-save-form");
            const elapsedField = document.getElementById("pl-elapsed-seconds");
            const saveModeField = document.getElementById("pl-save-mode");

            if (!root || !readout || !elapsedText || !stateLabel || !note || !progressFill ||
                !pauseButton || !exitButton || !confirmOverlay || !confirmCurrentTime ||
                !confirmTimerStatus || !confirmKeepGoingButton || !confirmStopButton ||
                !saveForm || !elapsedField || !saveModeField) {
                return;
            }

            const plannedSeconds = parseInt(root.dataset.plannedSeconds || "1500", 10);
            const stopThresholdSeconds = parseInt(root.dataset.stopThresholdSeconds || "60", 10);
            const stopThresholdText = root.dataset.stopThresholdText || "1 minute";

            let startedAtMs = Date.now();
            let pausedElapsedSeconds = 0;
            let isPaused = false;
            let isSubmitting = false;
            let isConfirmOpen = false;
            let completionTonePlayed = false;

            function formatClock(totalSeconds) {
                totalSeconds = Math.max(0, Math.floor(totalSeconds));

                const hours = Math.floor(totalSeconds / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;

                return `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
            }

            function getElapsedSeconds() {
                if (isPaused) {
                    return Math.min(plannedSeconds, pausedElapsedSeconds);
                }

                const liveElapsed = Math.floor((Date.now() - startedAtMs) / 1000);
                return Math.min(plannedSeconds, Math.max(0, liveElapsed));
            }

            function setButtonsDisabled(isDisabled) {
                pauseButton.disabled = isDisabled;
                exitButton.disabled = isDisabled;
                confirmKeepGoingButton.disabled = isDisabled;
                confirmStopButton.disabled = isDisabled;
            }

            function openConfirmOverlay() {
                isConfirmOpen = true;
                confirmOverlay.hidden = false;
                confirmOverlay.setAttribute("aria-hidden", "false");
                updateConfirmOverlay(getElapsedSeconds());
            }

            function closeConfirmOverlay() {
                isConfirmOpen = false;
                confirmOverlay.hidden = true;
                confirmOverlay.setAttribute("aria-hidden", "true");
            }

            function updateConfirmOverlay(elapsedSeconds) {
                confirmCurrentTime.textContent = formatClock(elapsedSeconds);
                confirmTimerStatus.textContent = isPaused ? "Paused" : "Still counting down";
            }

            function playCompletionTone() {
                if (completionTonePlayed) {
                    return;
                }

                completionTonePlayed = true;

                try {
                    const AudioContextClass = window.AudioContext || window.webkitAudioContext;

                    if (!AudioContextClass) {
                        return;
                    }

                    const audioContext = new AudioContextClass();
                    const oscillator = audioContext.createOscillator();
                    const gainNode = audioContext.createGain();

                    oscillator.type = "sine";
                    oscillator.frequency.value = 880;

                    gainNode.gain.setValueAtTime(0.0001, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.08, audioContext.currentTime + 0.02);
                    gainNode.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.35);

                    oscillator.connect(gainNode);
                    gainNode.connect(audioContext.destination);

                    oscillator.start();
                    oscillator.stop(audioContext.currentTime + 0.36);
                } catch {
                }
            }

            function submitSave(mode) {
                if (isSubmitting) {
                    return;
                }

                const elapsedSeconds = mode === "complete"
                    ? plannedSeconds
                    : getElapsedSeconds();

                if (elapsedSeconds <= 0) {
                    return;
                }

                isSubmitting = true;
                elapsedField.value = String(elapsedSeconds);
                saveModeField.value = mode;
                closeConfirmOverlay();
                setButtonsDisabled(true);
                saveForm.submit();
            }

            function updateExitButton(elapsedSeconds) {
                const canStop = elapsedSeconds >= stopThresholdSeconds;

                if (canStop) {
                    exitButton.textContent = "Stop Focusing";
                    exitButton.classList.add("pl-stop-button-armed");
                    return;
                }

                exitButton.textContent = "Cancel";
                exitButton.classList.remove("pl-stop-button-armed");
            }

            function updateUi() {
                const elapsedSeconds = getElapsedSeconds();
                const remainingSeconds = Math.max(0, plannedSeconds - elapsedSeconds);
                const progressPercent = plannedSeconds <= 0
                    ? 0
                    : (elapsedSeconds / plannedSeconds) * 100;

                readout.textContent = formatClock(remainingSeconds);
                elapsedText.textContent = formatClock(elapsedSeconds);
                progressFill.style.width = `${Math.max(0, Math.min(100, progressPercent))}%`;

                updateExitButton(elapsedSeconds);

                if (isConfirmOpen) {
                    updateConfirmOverlay(elapsedSeconds);
                }

                if (isPaused) {
                    stateLabel.textContent = "Paused";
                    pauseButton.textContent = "Keep Going?";
                    note.textContent = elapsedSeconds >= stopThresholdSeconds
                        ? "Session paused. You can keep going, or stop focusing and save the current incomplete session."
                        : `Session paused. Cancel before ${stopThresholdText} to discard this session with no save.`;
                } else {
                    stateLabel.textContent = "Time remaining";
                    pauseButton.textContent = "Pause";
                    note.textContent = elapsedSeconds >= stopThresholdSeconds
                        ? `You have reached ${stopThresholdText}. Stopping now will save the current session as incomplete.`
                        : `Cancel before ${stopThresholdText} to discard this session with no save.`;
                }

                if (remainingSeconds <= 0 && !isSubmitting) {
                    playCompletionTone();
                    submitSave("complete");
                }
            }

            pauseButton.addEventListener("click", function () {
                if (isSubmitting || isConfirmOpen) {
                    return;
                }

                if (!isPaused) {
                    pausedElapsedSeconds = getElapsedSeconds();
                    isPaused = true;
                    updateUi();
                    return;
                }

                startedAtMs = Date.now() - (pausedElapsedSeconds * 1000);
                isPaused = false;
                updateUi();
            });

            exitButton.addEventListener("click", function () {
                if (isSubmitting) {
                    return;
                }

                const elapsedSeconds = getElapsedSeconds();

                if (elapsedSeconds < stopThresholdSeconds) {
                    window.location.href = "/Index";
                    return;
                }

                openConfirmOverlay();
            });

            confirmKeepGoingButton.addEventListener("click", function () {
                if (isSubmitting) {
                    return;
                }

                closeConfirmOverlay();
            });

            confirmStopButton.addEventListener("click", function () {
                if (isSubmitting) {
                    return;
                }

                submitSave("stop");
            });

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape" && isConfirmOpen && !isSubmitting) {
                    closeConfirmOverlay();
                }
            });

            updateUi();
            window.setInterval(updateUi, 250);
        })();
    </script>
    <!-- SECTION B END — Countdown Timer Script -->
}
}